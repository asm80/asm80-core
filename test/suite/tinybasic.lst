0000                             ;*************************************************************
0000                             ; 
0000                             ;                 TINY BASIC FOR INTEL 8080
0000                             ;                       VERSION 2.0
0000                             ;                     BY LI-CHEN WANG
0000                             ;                  MODIFIED AND TRANSLATED
0000                             ;                    TO INTEL MNEMONICS
0000                             ;                     BY ROGER RAUSKOLB
0000                             ;                      10 OCTOBER,1976
0000                             ;                        @COPYLEFT
0000                             ;                   ALL WRONGS RESERVED
0000                             ; 
0000                             ;*************************************************************
0000                             ; 
0000                             ; *** ZERO PAGE SUBROUTINES ***
0000                             ; 
0000                             ; THE 8080 INSTRUCTION SET LETS YOU HAVE 8 ROUTINES IN LOW
0000                             ; MEMORY THAT MAY BE CALLED BY RST N, N BEING 0 THROUGH 7.
0000                             ; THIS IS A ONE BYTE INSTRUCTION AND HAS THE SAME POWER AS
0000                             ; THE THREE BYTE INSTRUCTION CALL LLHH.  TINY BASIC WILL
0000                             ; USE RST 0 AS START AND RST 1 THROUGH RST 7 FOR
0000                             ; THE SEVEN MOST FREQUENTLY USED SUBROUTINES.
0000                             ; TWO OTHER SUBROUTINES (CRLF AND TSTNUM) ARE ALSO IN THIS
0000                             ; SECTION.  THEY CAN BE REACHED ONLY BY 3-BYTE CALLS.
0000                             ; 
0000                             ; 
0000                          .ENGINE   alpha   
0000                .macro DWA,
0000                             ; 
0000                 DB      >%%1 + 128 
0000                 DB      <%%1 
0000                .endm
0000                 
0000                             ; 
1000                          .ORG   1000H   
1000                          .ENT   $   
1000   31 FF FF     START:    LXI   SP,STACK   ;*** COLD START ***
1003   3E FF                  MVI   A,0FFH   
1005   C3 BF 16               JMP   INIT   
1008                             ; 
1008                             ; 
1008   3E 0D        CRLF:     MVI   A,CR   ;*** CRLF ***
100A                             ; 
100A                RST2:        
100A                OUTC:        
100A   F5                     PUSH   PSW   ;*** OUTC OR RST 2 ***
100B   3A 00 80               LDA   OCSW   ;PRINT CHARACTER ONLY
100E   B7                     ORA   A   ;IF OCSW SWITCH IS ON
100F   C3 E9 16               JMP   OC2   ;REST OF THIS IS AT OC2
1012                             ; 
1012                RST3:        
1012                EXPR:        
1012   CD AC 13               CALL   EXPR2   ;*** EXPR OR RST 3 ***
1015   E5                     PUSH   H   ;EVALUATE AN EXPRESSION
1016   C3 68 13               JMP   EXPR1   ;REST OF IT AT EXPR1
1019   57                     DB   "W"   
101A                             ; 
101A                RST4:        
101A                COMP:        
101A   7C                     MOV   A,H   ;*** COMP OR RST 4 ***
101B   BA                     CMP   D   ;COMPARE HL WITH DE
101C   C0                     RNZ      ;RETURN CORRECT C AND
101D   7D                     MOV   A,L   ;Z FLAGS
101E   BB                     CMP   E   ;BUT OLD A IS LOST
101F   C9                     RET      
1020   41 4E                  DB   "AN"   
1022                             ; 
1022                RST5:        
1022                IGNBLK:      
1022   1A           SS1:      LDAX   D   ;*** IGNBLK/RST 5 ***
1023   FE 20                  CPI   20H   ;IGNORE BLANKS
1025   C0                     RNZ      ;IN TEXT (WHERE DE->)
1026   13                     INX   D   ;AND RETURN THE FIRST
1027   C3 22 10               JMP   SS1   ;NON-BLANK CHAR. IN A
102A                             ; 
102A                RST6:        
102A                FINISH:      
102A   F1                     POP   PSW   ;*** FINISH/RST 6 ***
102B   CD 0C 15               CALL   FIN   ;CHECK END OF COMMAND
102E   C3 25 15               JMP   QWHAT   ;PRINT "WHAT?" IF WRONG
1031   47                     DB   "G"   
1032                             ; 
1032                RST7:        
1032                TSTV:        
1032   CD 22 10               CALL   IGNBLK   ;*** TSTV OR RST 7 ***
1035   D6 40                  SUI   40H   ;TEST VARIABLES
1037   D8                     RC      ;C:NOT A VARIABLE
1038   C2 56 10               JNZ   TV1   ;NOT "@" ARRAY
103B   13                     INX   D   ;IT IS THE "@" ARRAY
103C   CD 63 14               CALL   PARN   ;@ SHOULD BE FOLLOWED
103F   29                     DAD   H   ;BY (EXPR) AS ITS INDEX
1040   DA A4 10               JC   QHOW   ;IS INDEX TOO BIG?
1043   D5                     PUSH   D   ;WILL IT OVERWRITE
1044   EB                     XCHG      ;TEXT?
1045   CD AA 14               CALL   SIZE   ;FIND SIZE OF FREE
1048   CD 1A 10               CALL   COMP   ;AND CHECK THAT
104B   DA 55 15               JC   ASORRY   ;IF SO, SAY "SORRY"
104E   21 00 FC               LXI   H,VARBGN   ;IF NOT GET ADDRESS
1051   CD CD 14               CALL   SUBDE   ;OF @(EXPR) AND PUT IT
1054   D1                     POP   D   ;IN HL
1055   C9                     RET      ;C FLAG IS CLEARED
1056   FE 1B        TV1:      CPI   1BH   ;NOT @, IS IT A TO Z?
1058   3F                     CMC      ;IF NOT RETURN C FLAG
1059   D8                     RC      
105A   13                     INX   D   ;IF A THROUGH Z
105B   21 00 FC               LXI   H,VARBGN   ;COMPUTE ADDRESS OF
105E   07                     RLC      ;THAT VARIABLE
105F   85                     ADD   L   ;AND RETURN IT IN HL
1060   6F                     MOV   L,A   ;WITH C FLAG CLEARED
1061   3E 00                  MVI   A,0   
1063   8C                     ADC   H   
1064   67                     MOV   H,A   
1065   C9                     RET      
1066                             ; 
1066                RST1:        
1066                TSTC:        
1066   E3                     XTHL      ;*** TSTC OR RST 1 ***
1067   CD 22 10               CALL   IGNBLK   ;IGNORE BLANKS AND
106A   BE                     CMP   M   ;TEST CHARACTER
106B   23           TC1:      INX   H   ;COMPARE THE BYTE THAT
106C   CA 76 10               JZ   TC2   ;FOLLOWS THE RST INST.
106F   C5                     PUSH   B   ;WITH THE TEXT (DE->)
1070   4E                     MOV   C,M   ;IF NOT =, ADD THE 2ND
1071   06 00                  MVI   B,0   ;BYTE THAT FOLLOWS THE
1073   09                     DAD   B   ;RST TO THE OLD PC
1074   C1                     POP   B   ;I.E., DO A RELATIVE
1075   1B                     DCX   D   ;JUMP IF NOT =
1076   13           TC2:      INX   D   ;IF =, SKIP THOSE BYTES
1077   23                     INX   H   ;AND CONTINUE
1078   E3                     XTHL      
1079   C9                     RET      
107A                             ; 
107A   21 00 00     TSTNUM:   LXI   H,0   ;*** TSTNUM ***
107D   44                     MOV   B,H   ;TEST IF THE TEXT IS
107E   CD 22 10               CALL   IGNBLK   ;A NUMBER
1081   FE 30        TN1:      CPI   30H   ;IF NOT, RETURN 0 IN
1083   D8                     RC      ;B AND HL
1084   FE 3A                  CPI   3AH   ;IF NUMBERS, CONVERT
1086   D0                     RNC      ;TO BINARY IN HL AND
1087   3E F0                  MVI   A,0F0H   ;SET B TO # OF DIGITS
1089   A4                     ANA   H   ;IF H>255, THERE IS NO
108A   C2 A4 10               JNZ   QHOW   ;ROOM FOR NEXT DIGIT
108D   04                     INR   B   ;B COUNTS # OF DIGITS
108E   C5                     PUSH   B   
108F   44                     MOV   B,H   ;HL=10*HL+(NEW DIGIT)
1090   4D                     MOV   C,L   
1091   29                     DAD   H   ;WHERE 10* IS DONE BY
1092   29                     DAD   H   ;SHIFT AND ADD
1093   09                     DAD   B   
1094   29                     DAD   H   
1095   1A                     LDAX   D   ;AND (DIGIT) IS FROM
1096   13                     INX   D   ;STRIPPING THE ASCII
1097   E6 0F                  ANI   0FH   ;CODE
1099   85                     ADD   L   
109A   6F                     MOV   L,A   
109B   3E 00                  MVI   A,0   
109D   8C                     ADC   H   
109E   67                     MOV   H,A   
109F   C1                     POP   B   
10A0   1A                     LDAX   D   ;DO THIS DIGIT AFTER
10A1   F2 81 10               JP   TN1   ;DIGIT. S SAYS OVERFLOW
10A4   D5           QHOW:     PUSH   D   ;*** ERROR "HOW?" ***
10A5   11 AB 10     AHOW:     LXI   D,HOW   
10A8   C3 29 15               JMP   ERROR   
10AB   48 4F 57 3F  HOW:      DB   "HOW?"   
10AF   0D                     DB   CR   
10B0   4F 4B        OK:       DB   "OK"   
10B2   0D                     DB   CR   
10B3   57 48 41 54 3F WHAT:   DB   "WHAT?"   
10B8   0D                     DB   CR   
10B9   53 4F 52 52 59 SORRY:   DB   "SORRY"   
10BE   0D                     DB   CR   
10BF                             ; 
10BF                             ;*************************************************************
10BF                             ; 
10BF                             ; *** MAIN ***
10BF                             ; 
10BF                             ; THIS IS THE MAIN LOOP THAT COLLECTS THE TINY BASIC PROGRAM
10BF                             ; AND STORES IT IN THE MEMORY.
10BF                             ; 
10BF                             ; AT START, IT PRINTS OUT "(CR)OK(CR)", AND INITIALIZES THE
10BF                             ; STACK AND SOME OTHER INTERNAL VARIABLES.  THEN IT PROMPTS
10BF                             ; ">" AND READS A LINE.  IF THE LINE STARTS WITH A NON-ZERO
10BF                             ; NUMBER, THIS NUMBER IS THE LINE NUMBER.  THE LINE NUMBER
10BF                             ; (IN 16 BIT BINARY) AND THE REST OF THE LINE (INCLUDING CR)
10BF                             ; IS STORED IN THE MEMORY.  IF A LINE WITH THE SAME LINE
10BF                             ; NUMBER IS ALREADY THERE, IT IS REPLACED BY THE NEW ONE.  IF
10BF                             ; THE REST OF THE LINE CONSISTS OF A CR ONLY, IT IS NOT STORED
10BF                             ; AND ANY EXISTING LINE WITH THE SAME LINE NUMBER IS DELETED.
10BF                             ; 
10BF                             ; AFTER A LINE IS INSERTED, REPLACED, OR DELETED, THE PROGRAM
10BF                             ; LOOPS BACK AND ASKS FOR ANOTHER LINE.  THIS LOOP WILL BE
10BF                             ; TERMINATED WHEN IT READS A LINE WITH ZERO OR NO LINE
10BF                             ; NUMBER; AND CONTROL IS TRANSFERED TO "DIRECT".
10BF                             ; 
10BF                             ; TINY BASIC PROGRAM SAVE AREA STARTS AT THE MEMORY LOCATION
10BF                             ; LABELED "TXTBGN" AND ENDS AT "TXTEND".  WE ALWAYS FILL THIS
10BF                             ; AREA STARTING AT "TXTBGN", THE UNFILLED PORTION IS POINTED
10BF                             ; BY THE CONTENT OF A MEMORY LOCATION LABELED "TXTUNF".
10BF                             ; 
10BF                             ; THE MEMORY LOCATION "CURRNT" POINTS TO THE LINE NUMBER
10BF                             ; THAT IS CURRENTLY BEING INTERPRETED.  WHILE WE ARE IN
10BF                             ; THIS LOOP OR WHILE WE ARE INTERPRETING A DIRECT COMMAND
10BF                             ; (SEE NEXT SECTION). "CURRNT" SHOULD POINT TO A 0.
10BF                             ; 
10BF   31 FF FF     RSTART:   LXI   SP,STACK   
10C2   CD 08 10     ST1:      CALL   CRLF   ;AND JUMP TO HERE
10C5   11 B0 10               LXI   D,OK   ;DE->STRING
10C8   97                     SUB   A   ;A=0
10C9   CD C9 15               CALL   PRTSTG   ;PRINT STRING UNTIL CR
10CC   21 D3 10               LXI   H,ST2+1   ;LITERAL 0
10CF   22 01 80               SHLD   CURRNT   ;CURRENT->LINE # = 0
10D2   21 00 00     ST2:      LXI   H,0   
10D5   22 09 80               SHLD   LOPVAR   
10D8   22 03 80               SHLD   STKGOS   
10DB   3E 3E        ST3:      MVI   A,3EH   ;PROMPT ">" AND
10DD   CD 5B 15               CALL   GETLN   ;READ A LINE
10E0   D5                     PUSH   D   ;DE->END OF LINE
10E1   11 37 FC               LXI   D,BUFFER   ;DE->BEGINNING OF LINE
10E4   CD 7A 10               CALL   TSTNUM   ;TEST IF IT IS A NUMBER
10E7   CD 22 10               CALL   IGNBLK   
10EA   7C                     MOV   A,H   ;HL=VALUE OF THE # OR
10EB   B5                     ORA   L   ;0 IF NO # WAS FOUND
10EC   C1                     POP   B   ;BC->END OF LINE
10ED   CA B7 17               JZ   DIRECT   
10F0   1B                     DCX   D   ;BACKUP DE AND SAVE
10F1   7C                     MOV   A,H   ;VALUE OF LINE # THERE
10F2   12                     STAX   D   
10F3   1B                     DCX   D   
10F4   7D                     MOV   A,L   
10F5   12                     STAX   D   
10F6   C5                     PUSH   B   ;BC,DE->BEGIN, END
10F7   D5                     PUSH   D   
10F8   79                     MOV   A,C   
10F9   93                     SUB   E   
10FA   F5                     PUSH   PSW   ;A=# OF BYTES IN LINE
10FB   CD 9F 15               CALL   FNDLN   ;FIND THIS LINE IN SAVE
10FE   D5                     PUSH   D   ;AREA, DE->SAVE AREA
10FF   C2 12 11               JNZ   ST4   ;NZ:NOT FOUND, INSERT
1102   D5                     PUSH   D   ;Z:FOUND, DELETE IT
1103   CD BD 15               CALL   FNDNXT   ;FIND NEXT LINE
1106                             ;DE->NEXT LINE
1106   C1                     POP   B   ;BC->LINE TO BE DELETED
1107   2A 15 80               LHLD   TXTUNF   ;HL->UNFILLED SAVE AREA
110A   CD 60 16               CALL   MVUP   ;MOVE UP TO DELETE
110D   60                     MOV   H,B   ;TXTUNF->UNFILLED AREA
110E   69                     MOV   L,C   
110F   22 15 80               SHLD   TXTUNF   ;UPDATE
1112   C1           ST4:      POP   B   ;GET READY TO INSERT
1113   2A 15 80               LHLD   TXTUNF   ;BUT FIRST CHECK IF
1116   F1                     POP   PSW   ;THE LENGTH OF NEW LINE
1117   E5                     PUSH   H   ;IS 3 (LINE # AND CR)
1118   FE 03                  CPI   3   ;THEN DO NOT INSERT
111A   CA BF 10               JZ   RSTART   ;MUST CLEAR THE STACK
111D   85                     ADD   L   ;COMPUTE NEW TXTUNF
111E   6F                     MOV   L,A   
111F   3E 00                  MVI   A,0   
1121   8C                     ADC   H   
1122   67                     MOV   H,A   ;HL->NEW UNFILLED AREA
1123   11 00 FC               LXI   D,TXTEND   ;CHECK TO SEE IF THERE
1126   CD 1A 10               CALL   COMP   ;IS ENOUGH SPACE
1129   D2 54 15               JNC   QSORRY   ;SORRY, NO ROOM FOR IT
112C   22 15 80               SHLD   TXTUNF   ;OK, UPDATE TXTUNF
112F   D1                     POP   D   ;DE->OLD UNFILLED AREA
1130   CD 6B 16               CALL   MVDOWN   
1133   D1                     POP   D   ;DE->BEGIN, HL->END
1134   E1                     POP   H   
1135   CD 60 16               CALL   MVUP   ;MOVE NEW LINE TO SAVE
1138   C3 DB 10               JMP   ST3   ;AREA
113B                             ; 
113B                             ;*************************************************************
113B                             ; 
113B                             ; WHAT FOLLOWS IS THE CODE TO EXECUTE DIRECT AND STATEMENT
113B                             ; COMMANDS.  CONTROL IS TRANSFERED TO THESE POINTS VIA THE
113B                             ; COMMAND TABLE LOOKUP CODE OF "DIRECT" AND "EXEC" IN LAST
113B                             ; SECTION.  AFTER THE COMMAND IS EXECUTED, CONTROL IS
113B                             ; TRANSFERED TO OTHERS SECTIONS AS FOLLOWS:
113B                             ; 
113B                             ; FOR "LIST", "NEW", AND "STOP": GO BACK TO "RSTART"
113B                             ; FOR "RUN": GO EXECUTE THE FIRST STORED LINE IF ANY, ELSE
113B                             ; GO BACK TO "RSTART".
113B                             ; FOR "GOTO" AND "GOSUB": GO EXECUTE THE TARGET LINE.
113B                             ; FOR "RETURN" AND "NEXT": GO BACK TO SAVED RETURN LINE.
113B                             ; FOR ALL OTHERS: IF "CURRENT" -> 0, GO TO "RSTART", ELSE
113B                             ; GO EXECUTE NEXT COMMAND.  (THIS IS DONE IN "FINISH".)
113B                             ;*************************************************************
113B                             ; 
113B                             ; *** NEW *** STOP *** RUN (& FRIENDS) *** & GOTO ***
113B                             ; 
113B                             ; "NEW(CR)" SETS "TXTUNF" TO POINT TO "TXTBGN"
113B                             ; 
113B                             ; "STOP(CR)" GOES BACK TO "RSTART"
113B                             ; 
113B                             ; "RUN(CR)" FINDS THE FIRST STORED LINE, STORE ITS ADDRESS (IN
113B                             ; "CURRENT"), AND START EXECUTE IT.  NOTE THAT ONLY THOSE
113B                             ; COMMANDS IN TAB2 ARE LEGAL FOR STORED PROGRAM.
113B                             ; 
113B                             ; THERE ARE 3 MORE ENTRIES IN "RUN":
113B                             ; "RUNNXL" FINDS NEXT LINE, STORES ITS ADDR. AND EXECUTES IT.
113B                             ; "RUNTSL" STORES THE ADDRESS OF THIS LINE AND EXECUTES IT.
113B                             ; "RUNSML" CONTINUES THE EXECUTION ON SAME LINE.
113B                             ; 
113B                             ; "GOTO EXPR(CR)" EVALUATES THE EXPRESSION, FIND THE TARGET
113B                             ; LINE, AND JUMP TO "RUNTSL" TO DO IT.
113B                             ; 
113B   CD 1F 15     NEW:      CALL   ENDCHK   ;*** NEW(CR) ***
113E   21 17 80               LXI   H,TXTBGN   
1141   22 15 80               SHLD   TXTUNF   
1144                             ; 
1144   CD 1F 15     STOP:     CALL   ENDCHK   ;*** STOP(CR) ***
1147   C3 BF 10               JMP   RSTART   
114A                             ; 
114A   CD 1F 15     RUN:      CALL   ENDCHK   ;*** RUN(CR) ***
114D   11 17 80               LXI   D,TXTBGN   ;FIRST SAVED LINE
1150                             ; 
1150   21 00 00     RUNNXL:   LXI   H,0   ;*** RUNNXL ***
1153   CD A7 15               CALL   FNDLP   ;FIND WHATEVER LINE #
1156   DA BF 10               JC   RSTART   ;C:PASSED TXTUNF, QUIT
1159                             ; 
1159   EB           RUNTSL:   XCHG      ;*** RUNTSL ***
115A   22 01 80               SHLD   CURRNT   ;SET "CURRENT"->LINE #
115D   EB                     XCHG      
115E   13                     INX   D   ;BUMP PASS LINE #
115F   13                     INX   D   
1160                             ; 
1160   CD 03 17     RUNSML:   CALL   CHKIO   ;*** RUNSML ***
1163   21 3C 17               LXI   H,TAB2-1   ;FIND COMMAND IN TAB2
1166   C3 BA 17               JMP   EXEC   ;AND EXECUTE IT
1169                             ; 
1169   CD 12 10     GOTO:     CALL   EXPR   ;*** GOTO EXPR ***
116C   D5                     PUSH   D   ;SAVE FOR ERROR ROUTINE
116D   CD 1F 15               CALL   ENDCHK   ;MUST FIND A CR
1170   CD 9F 15               CALL   FNDLN   ;FIND THE TARGET LINE
1173   C2 A5 10               JNZ   AHOW   ;NO SUCH LINE #
1176   F1                     POP   PSW   ;CLEAR THE PUSH DE
1177   C3 59 11               JMP   RUNTSL   ;GO DO IT
117A                             ; 
117A                             ;*************************************************************
117A                             ; 
117A                             ; *** LIST *** & PRINT ***
117A                             ; 
117A                             ; LIST HAS TWO FORMS:
117A                             ; "LIST(CR)" LISTS ALL SAVED LINES
117A                             ; "LIST #(CR)" START LIST AT THIS LINE #
117A                             ; YOU CAN STOP THE LISTING BY CONTROL C KEY
117A                             ; 
117A                             ; PRINT COMMAND IS "PRINT ....;" OR "PRINT ....(CR)"
117A                             ; WHERE "...." IS A LIST OF EXPRESIONS, FORMATS, BACK-
117A                             ; ARROWS, AND STRINGS.  THESE ITEMS ARE SEPERATED BY COMMAS.
117A                             ; 
117A                             ; A FORMAT IS A POUND SIGN FOLLOWED BY A NUMBER.  IT CONTROLS
117A                             ; THE NUMBER OF SPACES THE VALUE OF A EXPRESION IS GOING TO
117A                             ; BE PRINTED.  IT STAYS EFFECTIVE FOR THE REST OF THE PRINT
117A                             ; COMMAND UNLESS CHANGED BY ANOTHER FORMAT.  IF NO FORMAT IS
117A                             ; SPECIFIED, 6 POSITIONS WILL BE USED.
117A                             ; 
117A                             ; A STRING IS QUOTED IN A PAIR OF SINGLE QUOTES OR A PAIR OF
117A                             ; DOUBLE QUOTES.
117A                             ; 
117A                             ; A BACK-ARROW MEANS GENERATE A (CR) WITHOUT (LF)
117A                             ; 
117A                             ; A (CRLF) IS GENERATED AFTER THE ENTIRE LIST HAS BEEN
117A                             ; PRINTED OR IF THE LIST IS A NULL LIST.  HOWEVER IF THE LIST
117A                             ; ENDED WITH A COMMA, NO (CRLF) IS GENERATED.
117A                             ; 
117A   CD 7A 10     LIST:     CALL   TSTNUM   ;TEST IF THERE IS A #
117D   CD 1F 15               CALL   ENDCHK   ;IF NO # WE GET A 0
1180   CD 9F 15               CALL   FNDLN   ;FIND THIS OR NEXT LINE
1183   DA BF 10     LS1:      JC   RSTART   ;C:PASSED TXTUNF
1186   CD 4B 16               CALL   PRTLN   ;PRINT THE LINE
1189   CD 03 17               CALL   CHKIO   ;STOP IF HIT CONTROL-C
118C   CD A7 15               CALL   FNDLP   ;FIND NEXT LINE
118F   C3 83 11               JMP   LS1   ;AND LOOP BACK
1192                             ; 
1192   0E 06        PRINT:    MVI   C,6   ;C = # OF SPACES
1194   CD 66 10               CALL   TSTC   ;IF NULL LIST & ";"
1197   3B                     DB   3BH   
1198   06                     DB   PR2-$-1   
1199   CD 08 10               CALL   CRLF   ;GIVE CR-LF AND
119C   C3 60 11               JMP   RUNSML   ;CONTINUE SAME LINE
119F   CD 66 10     PR2:      CALL   TSTC   ;IF NULL LIST (CR)
11A2   0D                     DB   CR   
11A3   06                     DB   PR0-$-1   
11A4   CD 08 10               CALL   CRLF   ;ALSO GIVE CR-LF AND
11A7   C3 50 11               JMP   RUNNXL   ;GO TO NEXT LINE
11AA   CD 66 10     PR0:      CALL   TSTC   ;ELSE IS IT FORMAT?
11AD   23                     DB   "#"   
11AE   07                     DB   PR1-$-1   
11AF   CD 12 10               CALL   EXPR   ;YES, EVALUATE EXPR.
11B2   4D                     MOV   C,L   ;AND SAVE IT IN C
11B3   C3 BC 11               JMP   PR3   ;LOOK FOR MORE TO PRINT
11B6   CD D7 15     PR1:      CALL   QTSTG   ;OR IS IT A STRING?
11B9   C3 CD 11               JMP   PR8   ;IF NOT, MUST BE EXPR.
11BC   CD 66 10     PR3:      CALL   TSTC   ;IF ",", GO FIND NEXT
11BF   2C                     DB   ","   
11C0   06                     DB   PR6-$-1   
11C1   CD 0C 15               CALL   FIN   ;IN THE LIST.
11C4   C3 AA 11               JMP   PR0   ;LIST CONTINUES
11C7   CD 08 10     PR6:      CALL   CRLF   ;LIST ENDS
11CA   CD 2A 10               CALL   FINISH   
11CD   CD 12 10     PR8:      CALL   EXPR   ;EVALUATE THE EXPR
11D0   C5                     PUSH   B   
11D1   CD 07 16               CALL   PRTNUM   ;PRINT THE VALUE
11D4   C1                     POP   B   
11D5   C3 BC 11               JMP   PR3   ;MORE TO PRINT?
11D8                             ; 
11D8                             ;*************************************************************
11D8                             ; 
11D8                             ; *** GOSUB *** & RETURN ***
11D8                             ; 
11D8                             ; "GOSUB EXPR;" OR "GOSUB EXPR (CR)" IS LIKE THE "GOTO"
11D8                             ; COMMAND, EXCEPT THAT THE CURRENT TEXT POINTER, STACK POINTER
11D8                             ; ETC. ARE SAVE SO THAT EXECUTION CAN BE CONTINUED AFTER THE
11D8                             ; SUBROUTINE "RETURN".  IN ORDER THAT "GOSUB" CAN BE NESTED
11D8                             ; (AND EVEN RECURSIVE), THE SAVE AREA MUST BE STACKED.
11D8                             ; THE STACK POINTER IS SAVED IN "STKGOS", THE OLD "STKGOS" IS
11D8                             ; SAVED IN THE STACK.  IF WE ARE IN THE MAIN ROUTINE, "STKGOS"
11D8                             ; IS ZERO (THIS WAS DONE BY THE "MAIN" SECTION OF THE CODE),
11D8                             ; BUT WE STILL SAVE IT AS A FLAG FOR NO FURTHER "RETURN"S.
11D8                             ; 
11D8                             ; "RETURN(CR)" UNDOS EVERYTHING THAT "GOSUB" DID, AND THUS
11D8                             ; RETURN THE EXECUTION TO THE COMMAND AFTER THE MOST RECENT
11D8                             ; "GOSUB".  IF "STKGOS" IS ZERO, IT INDICATES THAT WE
11D8                             ; NEVER HAD A "GOSUB" AND IS THUS AN ERROR.
11D8                             ; 
11D8   CD 96 16     GOSUB:    CALL   PUSHA   ;SAVE THE CURRENT "FOR"
11DB   CD 12 10               CALL   EXPR   ;PARAMETERS
11DE   D5                     PUSH   D   ;AND TEXT POINTER
11DF   CD 9F 15               CALL   FNDLN   ;FIND THE TARGET LINE
11E2   C2 A5 10               JNZ   AHOW   ;NOT THERE. SAY "HOW?"
11E5   2A 01 80               LHLD   CURRNT   ;FOUND IT, SAVE OLD
11E8   E5                     PUSH   H   ;"CURRNT" OLD "STKGOS"
11E9   2A 03 80               LHLD   STKGOS   
11EC   E5                     PUSH   H   
11ED   21 00 00               LXI   H,0   ;AND LOAD NEW ONES
11F0   22 09 80               SHLD   LOPVAR   
11F3   39                     DAD   SP   
11F4   22 03 80               SHLD   STKGOS   
11F7   C3 59 11               JMP   RUNTSL   ;THEN RUN THAT LINE
11FA   CD 1F 15     RETURN:   CALL   ENDCHK   ;THERE MUST BE A CR
11FD   2A 03 80               LHLD   STKGOS   ;OLD STACK POINTER
1200   7C                     MOV   A,H   ;0 MEANS NOT EXIST
1201   B5                     ORA   L   
1202   CA 25 15               JZ   QWHAT   ;SO, WE SAY: "WHAT?"
1205   F9                     SPHL      ;ELSE, RESTORE IT
1206   E1                     POP   H   
1207   22 03 80               SHLD   STKGOS   ;AND THE OLD "STKGOS"
120A   E1                     POP   H   
120B   22 01 80               SHLD   CURRNT   ;AND THE OLD "CURRNT"
120E   D1                     POP   D   ;OLD TEXT POINTER
120F   CD 7A 16               CALL   POPA   ;OLD "FOR" PARAMETERS
1212   CD 2A 10               CALL   FINISH   ;AND WE ARE BACK HOME
1215                             ; 
1215                             ;*************************************************************
1215                             ; 
1215                             ; *** FOR *** & NEXT ***
1215                             ; 
1215                             ; "FOR" HAS TWO FORMS:
1215                             ; "FOR VAR=EXP1 TO EXP2 STEP EXP3" AND "FOR VAR=EXP1 TO EXP2"
1215                             ; THE SECOND FORM MEANS THE SAME THING AS THE FIRST FORM WITH
1215                             ; EXP3=1.  (I.E., WITH A STEP OF +1.)
1215                             ; TBI WILL FIND THE VARIABLE VAR, AND SET ITS VALUE TO THE
1215                             ; CURRENT VALUE OF EXP1.  IT ALSO EVALUATES EXP2 AND EXP3
1215                             ; AND SAVE ALL THESE TOGETHER WITH THE TEXT POINTER ETC. IN
1215                             ; THE "FOR" SAVE AREA, WHICH CONSISTS OF "LOPVAR", "LOPINC",
1215                             ; "LOPLMT", "LOPLN", AND "LOPPT".  IF THERE IS ALREADY SOME-
1215                             ; THING IN THE SAVE AREA (THIS IS INDICATED BY A NON-ZERO
1215                             ; "LOPVAR"), THEN THE OLD SAVE AREA IS SAVED IN THE STACK
1215                             ; BEFORE THE NEW ONE OVERWRITES IT.
1215                             ; TBI WILL THEN DIG IN THE STACK AND FIND OUT IF THIS SAME
1215                             ; VARIABLE WAS USED IN ANOTHER CURRENTLY ACTIVE "FOR" LOOP.
1215                             ; IF THAT IS THE CASE, THEN THE OLD "FOR" LOOP IS DEACTIVATED.
1215                             ; (PURGED FROM THE STACK..)
1215                             ; 
1215                             ; "NEXT VAR" SERVES AS THE LOGICAL (NOT NECESSARILLY PHYSICAL)
1215                             ; END OF THE "FOR" LOOP.  THE CONTROL VARIABLE VAR. IS CHECKED
1215                             ; WITH THE "LOPVAR".  IF THEY ARE NOT THE SAME, TBI DIGS IN
1215                             ; THE STACK TO FIND THE RIGHT ONE AND PURGES ALL THOSE THAT
1215                             ; DID NOT MATCH.  EITHER WAY, TBI THEN ADDS THE "STEP" TO
1215                             ; THAT VARIABLE AND CHECK THE RESULT WITH THE LIMIT.  IF IT
1215                             ; IS WITHIN THE LIMIT, CONTROL LOOPS BACK TO THE COMMAND
1215                             ; FOLLOWING THE "FOR".  IF OUTSIDE THE LIMIT, THE SAVE AREA
1215                             ; IS PURGED AND EXECUTION CONTINUES.
1215                             ; 
1215   CD 96 16     FOR:      CALL   PUSHA   ;SAVE THE OLD SAVE AREA
1218   CD F3 14               CALL   SETVAL   ;SET THE CONTROL VAR.
121B   2B                     DCX   H   ;HL IS ITS ADDRESS
121C   22 09 80               SHLD   LOPVAR   ;SAVE THAT
121F   21 92 17               LXI   H,TAB5-1   ;USE "EXEC" TO LOOK
1222   C3 BA 17               JMP   EXEC   ;FOR THE WORD "TO"
1225   CD 12 10     FR1:      CALL   EXPR   ;EVALUATE THE LIMIT
1228   22 0D 80               SHLD   LOPLMT   ;SAVE THAT
122B   21 98 17               LXI   H,TAB6-1   ;USE "EXEC" TO LOOK
122E   C3 BA 17               JMP   EXEC   ;FOR THE WORD "STEP"
1231   CD 12 10     FR2:      CALL   EXPR   ;FOUND IT, GET STEP
1234   C3 3A 12               JMP   FR4   
1237   21 01 00     FR3:      LXI   H,1H   ;NOT FOUND, SET TO 1
123A   22 0B 80     FR4:      SHLD   LOPINC   ;SAVE THAT TOO
123D   2A 01 80     FR5:      LHLD   CURRNT   ;SAVE CURRENT LINE #
1240   22 0F 80               SHLD   LOPLN   
1243   EB                     XCHG      ;AND TEXT POINTER
1244   22 11 80               SHLD   LOPPT   
1247   01 0A 00               LXI   B,0AH   ;DIG INTO STACK TO
124A   2A 09 80               LHLD   LOPVAR   ;FIND "LOPVAR"
124D   EB                     XCHG      
124E   60                     MOV   H,B   
124F   68                     MOV   L,B   ;HL=0 NOW
1250   39                     DAD   SP   ;HERE IS THE STACK
1251   3E                     DB   3EH   
1252   09           FR7:      DAD   B   ;EACH LEVEL IS 10 DEEP
1253   7E                     MOV   A,M   ;GET THAT OLD "LOPVAR"
1254   23                     INX   H   
1255   B6                     ORA   M   
1256   CA 73 12               JZ   FR8   ;0 SAYS NO MORE IN IT
1259   7E                     MOV   A,M   
125A   2B                     DCX   H   
125B   BA                     CMP   D   ;SAME AS THIS ONE?
125C   C2 52 12               JNZ   FR7   
125F   7E                     MOV   A,M   ;THE OTHER HALF?
1260   BB                     CMP   E   
1261   C2 52 12               JNZ   FR7   
1264   EB                     XCHG      ;YES, FOUND ONE
1265   21 00 00               LXI   H,0H   
1268   39                     DAD   SP   ;TRY TO MOVE SP
1269   44                     MOV   B,H   
126A   4D                     MOV   C,L   
126B   21 0A 00               LXI   H,0AH   
126E   19                     DAD   D   
126F   CD 6B 16               CALL   MVDOWN   ;AND PURGE 10 WORDS
1272   F9                     SPHL      ;IN THE STACK
1273   2A 11 80     FR8:      LHLD   LOPPT   ;JOB DONE, RESTORE DE
1276   EB                     XCHG      
1277   CD 2A 10               CALL   FINISH   ;AND CONTINUE
127A                             ; 
127A   CD 32 10     NEXT:     CALL   TSTV   ;GET ADDRESS OF VAR.
127D   DA 25 15               JC   QWHAT   ;NO VARIABLE, "WHAT?"
1280   22 05 80               SHLD   VARNXT   ;YES, SAVE IT
1283   D5           NX0:      PUSH   D   ;SAVE TEXT POINTER
1284   EB                     XCHG      
1285   2A 09 80               LHLD   LOPVAR   ;GET VAR. IN "FOR"
1288   7C                     MOV   A,H   
1289   B5                     ORA   L   ;0 SAYS NEVER HAD ONE
128A   CA 26 15               JZ   AWHAT   ;SO WE ASK: "WHAT?"
128D   CD 1A 10               CALL   COMP   ;ELSE WE CHECK THEM
1290   CA 9D 12               JZ   NX3   ;OK, THEY AGREE
1293   D1                     POP   D   ;NO, LET'S SEE
1294   CD 7A 16               CALL   POPA   ;PURGE CURRENT LOOP
1297   2A 05 80               LHLD   VARNXT   ;AND POP ONE LEVEL
129A   C3 83 12               JMP   NX0   ;GO CHECK AGAIN
129D   5E           NX3:      MOV   E,M   ;COME HERE WHEN AGREED
129E   23                     INX   H   
129F   56                     MOV   D,M   ;DE=VALUE OF VAR.
12A0   2A 0B 80               LHLD   LOPINC   
12A3   E5                     PUSH   H   
12A4   7C                     MOV   A,H   
12A5   AA                     XRA   D   
12A6   7A                     MOV   A,D   
12A7   19                     DAD   D   ;ADD ONE STEP
12A8   FA AF 12               JM   NX4   
12AB   AC                     XRA   H   
12AC   FA D3 12               JM   NX5   
12AF   EB           NX4:      XCHG      
12B0   2A 09 80               LHLD   LOPVAR   ;PUT IT BACK
12B3   73                     MOV   M,E   
12B4   23                     INX   H   
12B5   72                     MOV   M,D   
12B6   2A 0D 80               LHLD   LOPLMT   ;HL->LIMIT
12B9   F1                     POP   PSW   ;OLD HL
12BA   B7                     ORA   A   
12BB   F2 BF 12               JP   NX1   ;STEP > 0
12BE   EB                     XCHG      ;STEP < 0
12BF   CD E9 14     NX1:      CALL   CKHLDE   ;COMPARE WITH LIMIT
12C2   D1                     POP   D   ;RESTORE TEXT POINTER
12C3   DA D5 12               JC   NX2   ;OUTSIDE LIMIT
12C6   2A 0F 80               LHLD   LOPLN   ;WITHIN LIMIT, GO
12C9   22 01 80               SHLD   CURRNT   ;BACK TO THE SAVED
12CC   2A 11 80               LHLD   LOPPT   ;"CURRNT" AND TEXT
12CF   EB                     XCHG      ;POINTER
12D0   CD 2A 10               CALL   FINISH   
12D3   E1           NX5:      POP   H   
12D4   D1                     POP   D   
12D5   CD 7A 16     NX2:      CALL   POPA   ;PURGE THIS LOOP
12D8   CD 2A 10               CALL   FINISH   
12DB                             ; 
12DB                             ;*************************************************************
12DB                             ; 
12DB                             ; *** REM *** IF *** INPUT *** & LET (& DEFLT) ***
12DB                             ; 
12DB                             ; "REM" CAN BE FOLLOWED BY ANYTHING AND IS IGNORED BY TBI.
12DB                             ; TBI TREATS IT LIKE AN "IF" WITH A FALSE CONDITION.
12DB                             ; 
12DB                             ; "IF" IS FOLLOWED BY AN EXPR. AS A CONDITION AND ONE OR MORE
12DB                             ; COMMANDS (INCLUDING OTHER "IF"S) SEPERATED BY SEMI-COLONS.
12DB                             ; NOTE THAT THE WORD "THEN" IS NOT USED.  TBI EVALUATES THE
12DB                             ; EXPR. IF IT IS NON-ZERO, EXECUTION CONTINUES.  IF THE
12DB                             ; EXPR. IS ZERO, THE COMMANDS THAT FOLLOWS ARE IGNORED AND
12DB                             ; EXECUTION CONTINUES AT THE NEXT LINE.
12DB                             ; 
12DB                             ; "INPUT" COMMAND IS LIKE THE "PRINT" COMMAND, AND IS FOLLOWED
12DB                             ; BY A LIST OF ITEMS.  IF THE ITEM IS A STRING IN SINGLE OR
12DB                             ; DOUBLE QUOTES, OR IS A BACK-ARROW, IT HAS THE SAME EFFECT AS
12DB                             ; IN "PRINT".  IF AN ITEM IS A VARIABLE, THIS VARIABLE NAME IS
12DB                             ; PRINTED OUT FOLLOWED BY A COLON.  THEN TBI WAITS FOR AN
12DB                             ; EXPR. TO BE TYPED IN.  THE VARIABLE IS THEN SET TO THE
12DB                             ; VALUE OF THIS EXPR.  IF THE VARIABLE IS PROCEDED BY A STRING
12DB                             ; (AGAIN IN SINGLE OR DOUBLE QUOTES), THE STRING WILL BE
12DB                             ; PRINTED FOLLOWED BY A COLON.  TBI THEN WAITS FOR INPUT EXPR.
12DB                             ; AND SET THE VARIABLE TO THE VALUE OF THE EXPR.
12DB                             ; 
12DB                             ; IF THE INPUT EXPR. IS INVALID, TBI WILL PRINT "WHAT?",
12DB                             ; "HOW?" OR "SORRY" AND REPRINT THE PROMPT AND REDO THE INPUT.
12DB                             ; THE EXECUTION WILL NOT TERMINATE UNLESS YOU TYPE CONTROL-C.
12DB                             ; THIS IS HANDLED IN "INPERR".
12DB                             ; 
12DB                             ; "LET" IS FOLLOWED BY A LIST OF ITEMS SEPERATED BY COMMAS.
12DB                             ; EACH ITEM CONSISTS OF A VARIABLE, AN EQUAL SIGN, AND AN EXPR.
12DB                             ; TBI EVALUATES THE EXPR. AND SET THE VARIABLE TO THAT VALUE.
12DB                             ; TBI WILL ALSO HANDLE "LET" COMMAND WITHOUT THE WORD "LET".
12DB                             ; THIS IS DONE BY "DEFLT".
12DB                             ; 
12DB   21 00 00     REM:      LXI   H,0H   ;*** REM ***
12DE   3E                     DB   3EH   ;THIS IS LIKE "IF 0"
12DF                             ; 
12DF   CD 12 10     IFF:      CALL   EXPR   ;*** IF ***
12E2   7C                     MOV   A,H   ;IS THE EXPR.=0?
12E3   B5                     ORA   L   
12E4   C2 60 11               JNZ   RUNSML   ;NO, CONTINUE
12E7   CD BF 15               CALL   FNDSKP   ;YES, SKIP REST OF LINE
12EA   D2 59 11               JNC   RUNTSL   ;AND RUN THE NEXT LINE
12ED   C3 BF 10               JMP   RSTART   ;IF NO NEXT, RE-START
12F0                             ; 
12F0   2A 07 80     INPERR:   LHLD   STKINP   ;*** INPERR ***
12F3   F9                     SPHL      ;RESTORE OLD SP
12F4   E1                     POP   H   ;AND OLD "CURRNT"
12F5   22 01 80               SHLD   CURRNT   
12F8   D1                     POP   D   ;AND OLD TEXT POINTER
12F9   D1                     POP   D   ;REDO INPUT
12FA                             ; 
12FA                INPUT:       ;*** INPUT ***
12FA   D5           IP1:      PUSH   D   ;SAVE IN CASE OF ERROR
12FB   CD D7 15               CALL   QTSTG   ;IS NEXT ITEM A STRING?
12FE   C3 0A 13               JMP   IP2   ;NO
1301   CD 32 10               CALL   TSTV   ;YES, BUT FOLLOWED BY A
1304   DA 48 13               JC   IP4   ;VARIABLE?   NO.
1307   C3 1C 13               JMP   IP3   ;YES.  INPUT VARIABLE
130A   D5           IP2:      PUSH   D   ;SAVE FOR "PRTSTG"
130B   CD 32 10               CALL   TSTV   ;MUST BE VARIABLE NOW
130E   DA 25 15               JC   QWHAT   ;"WHAT?" IT IS NOT?
1311   1A                     LDAX   D   ;GET READY FOR "PRTSTR"
1312   4F                     MOV   C,A   
1313   97                     SUB   A   
1314   12                     STAX   D   
1315   D1                     POP   D   
1316   CD C9 15               CALL   PRTSTG   ;PRINT STRING AS PROMPT
1319   79                     MOV   A,C   ;RESTORE TEXT
131A   1B                     DCX   D   
131B   12                     STAX   D   
131C   D5           IP3:      PUSH   D   ;SAVE TEXT POINTER
131D   EB                     XCHG      
131E   2A 01 80               LHLD   CURRNT   ;ALSO SAVE "CURRNT"
1321   E5                     PUSH   H   
1322   21 FA 12               LXI   H,IP1   ;A NEGATIVE NUMBER
1325   22 01 80               SHLD   CURRNT   ;AS A FLAG
1328   21 00 00               LXI   H,0H   ;SAVE SP TOO
132B   39                     DAD   SP   
132C   22 07 80               SHLD   STKINP   
132F   D5                     PUSH   D   ;OLD HL
1330   3E 3A                  MVI   A,3AH   ;PRINT THIS TOO
1332   CD 5B 15               CALL   GETLN   ;AND GET A LINE
1335   11 37 FC               LXI   D,BUFFER   ;POINTS TO BUFFER
1338   CD 12 10               CALL   EXPR   ;EVALUATE INPUT
133B   00                     NOP      ;CAN BE "CALL ENDCHK"
133C   00                     NOP      
133D   00                     NOP      
133E   D1                     POP   D   ;OK, GET OLD HL
133F   EB                     XCHG      
1340   73                     MOV   M,E   ;SAVE VALUE IN VAR.
1341   23                     INX   H   
1342   72                     MOV   M,D   
1343   E1                     POP   H   ;GET OLD "CURRNT"
1344   22 01 80               SHLD   CURRNT   
1347   D1                     POP   D   ;AND OLD TEXT POINTER
1348   F1           IP4:      POP   PSW   ;PURGE JUNK IN STACK
1349   CD 66 10               CALL   TSTC   ;IS NEXT CH. ","?
134C   2C                     DB   ","   
134D   03                     DB   IP5-$-1   
134E   C3 FA 12               JMP   IP1   ;YES, MORE ITEMS.
1351   CD 2A 10     IP5:      CALL   FINISH   
1354                             ; 
1354   1A           DEFLT:    LDAX   D   ;***  DEFLT ***
1355   FE 0D                  CPI   CR   ;EMPTY LINE IS OK
1357   CA 65 13               JZ   LT1   ;ELSE IT IS "LET"
135A                             ; 
135A   CD F3 14     LET:      CALL   SETVAL   ;*** LET ***
135D   CD 66 10               CALL   TSTC   ;SET VALUE TO VAR.
1360   2C                     DB   ","   
1361   03                     DB   LT1-$-1   
1362   C3 5A 13               JMP   LET   ;ITEM BY ITEM
1365   CD 2A 10     LT1:      CALL   FINISH   ;UNTIL FINISH
1368                             ; 
1368                             ;*************************************************************
1368                             ; 
1368                             ; *** EXPR ***
1368                             ; 
1368                             ; "EXPR" EVALUATES ARITHMETICAL OR LOGICAL EXPRESSIONS.
1368                             ; <EXPR>::<EXPR2>
1368                             ;         <EXPR2><REL.OP.><EXPR2>
1368                             ; WHERE <REL.OP.> IS ONE OF THE OPERATORS IN TAB8 AND THE
1368                             ; RESULT OF THESE OPERATIONS IS 1 IF TRUE AND 0 IF FALSE.
1368                             ; <EXPR2>::=(+ OR -)<EXPR3>(+ OR -<EXPR3>)(....)
1368                             ; WHERE () ARE OPTIONAL AND (....) ARE OPTIONAL REPEATS.
1368                             ; <EXPR3>::=<EXPR4>(* OR /><EXPR4>)(....)
1368                             ; <EXPR4>::=<VARIABLE>
1368                             ;           <FUNCTION>
1368                             ;           (<EXPR>)
1368                             ; <EXPR> IS RECURSIVE SO THAT VARIABLE "@" CAN HAVE AN <EXPR>
1368                             ; AS INDEX, FUNCTIONS CAN HAVE AN <EXPR> AS ARGUMENTS, AND
1368                             ; <EXPR4> CAN BE AN <EXPR> IN PARANTHESE.
1368                             ; 
1368                             ;EXPR:  CALL EXPR2                      ;THIS IS AT LOC. 18
1368                             ;       PUSH H                          ;SAVE <EXPR2> VALUE
1368   21 A0 17     EXPR1:    LXI   H,TAB8-1   ;LOOKUP REL.OP.
136B   C3 BA 17               JMP   EXEC   ;GO DO IT
136E   CD 97 13     XP11:     CALL   XP18   ;REL.OP.">="
1371   D8                     RC      ;NO, RETURN HL=0
1372   6F                     MOV   L,A   ;YES, RETURN HL=1
1373   C9                     RET      
1374   CD 97 13     XP12:     CALL   XP18   ;REL.OP."#"
1377   C8                     RZ      ;FALSE, RETURN HL=0
1378   6F                     MOV   L,A   ;TRUE, RETURN HL=1
1379   C9                     RET      
137A   CD 97 13     XP13:     CALL   XP18   ;REL.OP.">"
137D   C8                     RZ      ;FALSE
137E   D8                     RC      ;ALSO FALSE, HL=0
137F   6F                     MOV   L,A   ;TRUE, HL=1
1380   C9                     RET      
1381   CD 97 13     XP14:     CALL   XP18   ;REL.OP."<="
1384   6F                     MOV   L,A   ;SET HL=1
1385   C8                     RZ      ;REL. TRUE, RETURN
1386   D8                     RC      
1387   6C                     MOV   L,H   ;ELSE SET HL=0
1388   C9                     RET      
1389   CD 97 13     XP15:     CALL   XP18   ;REL.OP."="
138C   C0                     RNZ      ;FALSE, RETURN HL=0
138D   6F                     MOV   L,A   ;ELSE SET HL=1
138E   C9                     RET      
138F   CD 97 13     XP16:     CALL   XP18   ;REL.OP."<"
1392   D0                     RNC      ;FALSE, RETURN HL=0
1393   6F                     MOV   L,A   ;ELSE SET HL=1
1394   C9                     RET      
1395   E1           XP17:     POP   H   ;NOT .REL.OP
1396   C9                     RET      ;RETURN HL=<EXPR2>
1397   79           XP18:     MOV   A,C   ;SUBROUTINE FOR ALL
1398   E1                     POP   H   ;REL.OP.'S
1399   C1                     POP   B   
139A   E5                     PUSH   H   ;REVERSE TOP OF STACK
139B   C5                     PUSH   B   
139C   4F                     MOV   C,A   
139D   CD AC 13               CALL   EXPR2   ;GET 2ND <EXPR2>
13A0   EB                     XCHG      ;VALUE IN DE NOW
13A1   E3                     XTHL      ;1ST <EXPR2> IN HL
13A2   CD E9 14               CALL   CKHLDE   ;COMPARE 1ST WITH 2ND
13A5   D1                     POP   D   ;RESTORE TEXT POINTER
13A6   21 00 00               LXI   H,0H   ;SET HL=0, A=1
13A9   3E 01                  MVI   A,1   
13AB   C9                     RET      
13AC                             ; 
13AC   CD 66 10     EXPR2:    CALL   TSTC   ;NEGATIVE SIGN?
13AF   2D                     DB   "-"   
13B0   06                     DB   XP21-$-1   
13B1   21 00 00               LXI   H,0H   ;YES, FAKE "0-"
13B4   C3 DE 13               JMP   XP26   ;TREAT LIKE SUBTRACT
13B7   CD 66 10     XP21:     CALL   TSTC   ;POSITIVE SIGN? IGNORE
13BA   2B                     DB   "+"   
13BB   00                     DB   XP22-$-1   
13BC   CD E8 13     XP22:     CALL   EXPR3   ;1ST <EXPR3>
13BF   CD 66 10     XP23:     CALL   TSTC   ;ADD?
13C2   2B                     DB   "+"   
13C3   15                     DB   XP25-$-1   
13C4   E5                     PUSH   H   ;YES, SAVE VALUE
13C5   CD E8 13               CALL   EXPR3   ;GET 2ND <EXPR3>
13C8   EB           XP24:     XCHG      ;2ND IN DE
13C9   E3                     XTHL      ;1ST IN HL
13CA   7C                     MOV   A,H   ;COMPARE SIGN
13CB   AA                     XRA   D   
13CC   7A                     MOV   A,D   
13CD   19                     DAD   D   
13CE   D1                     POP   D   ;RESTORE TEXT POINTER
13CF   FA BF 13               JM   XP23   ;1ST AND 2ND SIGN DIFFER
13D2   AC                     XRA   H   ;1ST AND 2ND SIGN EQUAL
13D3   F2 BF 13               JP   XP23   ;SO IS RESULT
13D6   C3 A4 10               JMP   QHOW   ;ELSE WE HAVE OVERFLOW
13D9   CD 66 10     XP25:     CALL   TSTC   ;SUBTRACT?
13DC   2D                     DB   "-"   
13DD   92                     DB   XP42-$-1   
13DE   E5           XP26:     PUSH   H   ;YES, SAVE 1ST <EXPR3>
13DF   CD E8 13               CALL   EXPR3   ;GET 2ND <EXPR3>
13E2   CD D7 14               CALL   CHGSGN   ;NEGATE
13E5   C3 C8 13               JMP   XP24   ;AND ADD THEM
13E8                             ; 
13E8   CD 4C 14     EXPR3:    CALL   EXPR4   ;GET 1ST <EXPR4>
13EB   CD 66 10     XP31:     CALL   TSTC   ;MULTIPLY?
13EE   2A                     DB   "*"   
13EF   2D                     DB   XP34-$-1   
13F0   E5                     PUSH   H   ;YES, SAVE 1ST
13F1   CD 4C 14               CALL   EXPR4   ;AND GET 2ND <EXPR4>
13F4   06 00                  MVI   B,0H   ;CLEAR B FOR SIGN
13F6   CD D4 14               CALL   CHKSGN   ;CHECK SIGN
13F9   E3                     XTHL      ;1ST IN HL
13FA   CD D4 14               CALL   CHKSGN   ;CHECK SIGN OF 1ST
13FD   EB                     XCHG      
13FE   E3                     XTHL      
13FF   7C                     MOV   A,H   ;IS HL > 255 ?
1400   B7                     ORA   A   
1401   CA 0A 14               JZ   XP32   ;NO
1404   7A                     MOV   A,D   ;YES, HOW ABOUT DE
1405   B2                     ORA   D   
1406   EB                     XCHG      ;PUT SMALLER IN HL
1407   C2 A5 10               JNZ   AHOW   ;ALSO >, WILL OVERFLOW
140A   7D           XP32:     MOV   A,L   ;THIS IS DUMB
140B   21 00 00               LXI   H,0H   ;CLEAR RESULT
140E   B7                     ORA   A   ;ADD AND COUNT
140F   CA 3E 14               JZ   XP35   
1412   19           XP33:     DAD   D   
1413   DA A5 10               JC   AHOW   ;OVERFLOW
1416   3D                     DCR   A   
1417   C2 12 14               JNZ   XP33   
141A   C3 3E 14               JMP   XP35   ;FINISHED
141D   CD 66 10     XP34:     CALL   TSTC   ;DIVIDE?
1420   2F                     DB   "/"   
1421   4E                     DB   XP42-$-1   
1422   E5                     PUSH   H   ;YES, SAVE 1ST <EXPR4>
1423   CD 4C 14               CALL   EXPR4   ;AND GET THE SECOND ONE
1426   06 00                  MVI   B,0H   ;CLEAR B FOR SIGN
1428   CD D4 14               CALL   CHKSGN   ;CHECK SIGN OF 2ND
142B   E3                     XTHL      ;GET 1ST IN HL
142C   CD D4 14               CALL   CHKSGN   ;CHECK SIGN OF 1ST
142F   EB                     XCHG      
1430   E3                     XTHL      
1431   EB                     XCHG      
1432   7A                     MOV   A,D   ;DIVIDE BY 0?
1433   B3                     ORA   E   
1434   CA A5 10               JZ   AHOW   ;SAY "HOW?"
1437   C5                     PUSH   B   ;ELSE SAVE SIGN
1438   CD B7 14               CALL   DIVIDE   ;USE SUBROUTINE
143B   60                     MOV   H,B   ;RESULT IN HL NOW
143C   69                     MOV   L,C   
143D   C1                     POP   B   ;GET SIGN BACK
143E   D1           XP35:     POP   D   ;AND TEXT POINTER
143F   7C                     MOV   A,H   ;HL MUST BE +
1440   B7                     ORA   A   
1441   FA A4 10               JM   QHOW   ;ELSE IT IS OVERFLOW
1444   78                     MOV   A,B   
1445   B7                     ORA   A   
1446   FC D7 14               CM   CHGSGN   ;CHANGE SIGN IF NEEDED
1449   C3 EB 13               JMP   XP31   ;LOOK FOR MORE TERMS
144C                             ; 
144C   21 80 17     EXPR4:    LXI   H,TAB4-1   ;FIND FUNCTION IN TAB4
144F   C3 BA 17               JMP   EXEC   ;AND GO DO IT
1452   CD 32 10     XP40:     CALL   TSTV   ;NO, NOT A FUNCTION
1455   DA 5D 14               JC   XP41   ;NOR A VARIABLE
1458   7E                     MOV   A,M   ;VARIABLE
1459   23                     INX   H   
145A   66                     MOV   H,M   ;VALUE IN HL
145B   6F                     MOV   L,A   
145C   C9                     RET      
145D   CD 7A 10     XP41:     CALL   TSTNUM   ;OR IS IT A NUMBER
1460   78                     MOV   A,B   ;# OF DIGIT
1461   B7                     ORA   A   
1462   C0                     RNZ      ;OK
1463   CD 66 10     PARN:     CALL   TSTC   
1466   28                     DB   "("   
1467   09                     DB   XP43-$-1   
1468   CD 12 10               CALL   EXPR   ;"(EXPR)"
146B   CD 66 10               CALL   TSTC   
146E   29                     DB   ")"   
146F   01                     DB   XP43-$-1   
1470   C9           XP42:     RET      
1471   C3 25 15     XP43:     JMP   QWHAT   ;ELSE SAY: "WHAT?"
1474                             ; 
1474   CD 63 14     RND:      CALL   PARN   ;*** RND(EXPR) ***
1477   7C                     MOV   A,H   ;EXPR MUST BE +
1478   B7                     ORA   A   
1479   FA A4 10               JM   QHOW   
147C   B5                     ORA   L   ;AND NON-ZERO
147D   CA A4 10               JZ   QHOW   
1480   D5                     PUSH   D   ;SAVE BOTH
1481   E5                     PUSH   H   
1482   2A 13 80               LHLD   RANPNT   ;GET MEMORY AS RANDOM
1485   11 EA 17               LXI   D,LSTROM   ;NUMBER
1488   CD 1A 10               CALL   COMP   
148B   DA 91 14               JC   RA1   ;WRAP AROUND IF LAST
148E   21 00 10               LXI   H,START   
1491   5E           RA1:      MOV   E,M   
1492   23                     INX   H   
1493   56                     MOV   D,M   
1494   22 13 80               SHLD   RANPNT   
1497   E1                     POP   H   
1498   EB                     XCHG      
1499   C5                     PUSH   B   
149A   CD B7 14               CALL   DIVIDE   ;RND(N)=MOD(M,N)+1
149D   C1                     POP   B   
149E   D1                     POP   D   
149F   23                     INX   H   
14A0   C9                     RET      
14A1                             ; 
14A1   CD 63 14     ABS:      CALL   PARN   ;*** ABS(EXPR) ***
14A4   1B                     DCX   D   
14A5   CD D4 14               CALL   CHKSGN   ;CHECK SIGN
14A8   13                     INX   D   
14A9   C9                     RET      
14AA                             ; 
14AA   2A 15 80     SIZE:     LHLD   TXTUNF   ;*** SIZE ***
14AD   D5                     PUSH   D   ;GET THE NUMBER OF FREE
14AE   EB                     XCHG      ;BYTES BETWEEN "TXTUNF"
14AF   21 00 FC               LXI   H,VARBGN   ;AND "VARBGN"
14B2   CD CD 14               CALL   SUBDE   
14B5   D1                     POP   D   
14B6   C9                     RET      
14B7                             ; 
14B7                             ;*************************************************************
14B7                             ; 
14B7                             ; *** DIVIDE *** SUBDE *** CHKSGN *** CHGSGN *** & CKHLDE ***
14B7                             ; 
14B7                             ; "DIVIDE" DIVIDES HL BY DE, RESULT IN BC, REMAINDER IN HL
14B7                             ; 
14B7                             ; "SUBDE" SUBSTRACTS DE FROM HL
14B7                             ; 
14B7                             ; "CHKSGN" CHECKS SIGN OF HL.  IF +, NO CHANGE.  IF -, CHANGE
14B7                             ; SIGN AND FLIP SIGN OF B.
14B7                             ; 
14B7                             ; "CHGSGN" CHECKS SIGN N OF HL AND B UNCONDITIONALLY.
14B7                             ; 
14B7                             ; "CKHLDE" CHECKS SIGN OF HL AND DE.  IF DIFFERENT, HL AND DE
14B7                             ; ARE INTERCHANGED.  IF SAME SIGN, NOT INTERCHANGED.  EITHER
14B7                             ; CASE, HL DE ARE THEN COMPARED TO SET THE FLAGS.
14B7                             ; 
14B7   E5           DIVIDE:   PUSH   H   ;*** DIVIDE ***
14B8   6C                     MOV   L,H   ;DIVIDE H BY DE
14B9   26 00                  MVI   H,0   
14BB   CD C2 14               CALL   DV1   
14BE   41                     MOV   B,C   ;SAVE RESULT IN B
14BF   7D                     MOV   A,L   ;(REMINDER+L)/DE
14C0   E1                     POP   H   
14C1   67                     MOV   H,A   
14C2   0E FF        DV1:      MVI   C,0FFH   ;RESULT IN C
14C4   0C           DV2:      INR   C   ;DUMB ROUTINE
14C5   CD CD 14               CALL   SUBDE   ;DIVIDE BY SUBTRACT
14C8   D2 C4 14               JNC   DV2   ;AND COUNT
14CB   19                     DAD   D   
14CC   C9                     RET      
14CD                             ; 
14CD   7D           SUBDE:    MOV   A,L   ;*** SUBDE ***
14CE   93                     SUB   E   ;SUBSTRACT DE FROM
14CF   6F                     MOV   L,A   ;HL
14D0   7C                     MOV   A,H   
14D1   9A                     SBB   D   
14D2   67                     MOV   H,A   
14D3   C9                     RET      
14D4                             ; 
14D4   7C           CHKSGN:   MOV   A,H   ;*** CHKSGN ***
14D5   B7                     ORA   A   ;CHECK SIGN OF HL
14D6   F0                     RP      ;IF -, CHANGE SIGN
14D7                             ; 
14D7   7C           CHGSGN:   MOV   A,H   ;*** CHGSGN ***
14D8   F5                     PUSH   PSW   
14D9   2F                     CMA      ;CHANGE SIGN OF HL
14DA   67                     MOV   H,A   
14DB   7D                     MOV   A,L   
14DC   2F                     CMA      
14DD   6F                     MOV   L,A   
14DE   23                     INX   H   
14DF   F1                     POP   PSW   
14E0   AC                     XRA   H   
14E1   F2 A4 10               JP   QHOW   
14E4   78                     MOV   A,B   ;AND ALSO FLIP B
14E5   EE 80                  XRI   80H   
14E7   47                     MOV   B,A   
14E8   C9                     RET      
14E9                             ; 
14E9   7C           CKHLDE:   MOV   A,H   
14EA   AA                     XRA   D   ;SAME SIGN?
14EB   F2 EF 14               JP   CK1   ;YES, COMPARE
14EE   EB                     XCHG      ;NO, XCH AND COMP
14EF   CD 1A 10     CK1:      CALL   COMP   
14F2   C9                     RET      
14F3                             ; 
14F3                             ;*************************************************************
14F3                             ; 
14F3                             ; *** SETVAL *** FIN *** ENDCHK *** & ERROR (& FRIENDS) ***
14F3                             ; 
14F3                             ; "SETVAL" EXPECTS A VARIABLE, FOLLOWED BY AN EQUAL SIGN AND
14F3                             ; THEN AN EXPR.  IT EVALUATES THE EXPR. AND SET THE VARIABLE
14F3                             ; TO THAT VALUE.
14F3                             ; 
14F3                             ; "FIN" CHECKS THE END OF A COMMAND.  IF IT ENDED WITH "§",
14F3                             ; EXECUTION CONTINUES.  IF IT ENDED WITH A CR, IT FINDS THE
14F3                             ; NEXT LINE AND CONTINUE FROM THERE.
14F3                             ; 
14F3                             ; "ENDCHK" CHECKS IF A COMMAND IS ENDED WITH CR.  THIS IS
14F3                             ; REQUIRED IN CERTAIN COMMANDS.  (GOTO, RETURN, AND STOP ETC.)
14F3                             ; 
14F3                             ; "ERROR" PRINTS THE STRING POINTED BY DE (AND ENDS WITH CR).
14F3                             ; IT THEN PRINTS THE LINE POINTED BY "CURRNT" WITH A "?"
14F3                             ; INSERTED AT WHERE THE OLD TEXT POINTER (SHOULD BE ON TOP
14F3                             ; OF THE STACK) POINTS TO.  EXECUTION OF TB IS STOPPED
14F3                             ; AND TBI IS RESTARTED.  HOWEVER, IF "CURRNT" -> ZERO
14F3                             ; (INDICATING A DIRECT COMMAND), THE DIRECT COMMAND IS NOT
14F3                             ; PRINTED.  AND IF "CURRNT" -> NEGATIVE # (INDICATING "INPUT"
14F3                             ; COMMAND), THE INPUT LINE IS NOT PRINTED AND EXECUTION IS
14F3                             ; NOT TERMINATED BUT CONTINUED AT "INPERR".
14F3                             ; 
14F3                             ; RELATED TO "ERROR" ARE THE FOLLOWING:
14F3                             ; "QWHAT" SAVES TEXT POINTER IN STACK AND GET MESSAGE "WHAT?"
14F3                             ; "AWHAT" JUST GET MESSAGE "WHAT?" AND JUMP TO "ERROR".
14F3                             ; "QSORRY" AND "ASORRY" DO SAME KIND OF THING.
14F3                             ; "AHOW" AND "AHOW" IN THE ZERO PAGE SECTION ALSO DO THIS.
14F3                             ; 
14F3   CD 32 10     SETVAL:   CALL   TSTV   ;*** SETVAL ***
14F6   DA 25 15               JC   QWHAT   ;"WHAT?" NO VARIABLE
14F9   E5                     PUSH   H   ;SAVE ADDRESS OF VAR.
14FA   CD 66 10               CALL   TSTC   ;PASS "=" SIGN
14FD   3D                     DB   "="   
14FE   0A                     DB   SV1-$-1   
14FF   CD 12 10               CALL   EXPR   ;EVALUATE EXPR.
1502   44                     MOV   B,H   ;VALUE IS IN BC NOW
1503   4D                     MOV   C,L   
1504   E1                     POP   H   ;GET ADDRESS
1505   71                     MOV   M,C   ;SAVE VALUE
1506   23                     INX   H   
1507   70                     MOV   M,B   
1508   C9                     RET      
1509   C3 25 15     SV1:      JMP   QWHAT   ;NO "=" SIGN
150C                             ; 
150C   CD 66 10     FIN:      CALL   TSTC   ;*** FIN ***
150F   3B                     DB   3BH   
1510   04                     DB   FI1-$-1   
1511   F1                     POP   PSW   ;";", PURGE RET. ADDR.
1512   C3 60 11               JMP   RUNSML   ;CONTINUE SAME LINE
1515   CD 66 10     FI1:      CALL   TSTC   ;NOT ";", IS IT CR?
1518   0D                     DB   CR   
1519   04                     DB   FI2-$-1   
151A   F1                     POP   PSW   ;YES, PURGE RET. ADDR.
151B   C3 50 11               JMP   RUNNXL   ;RUN NEXT LINE
151E   C9           FI2:      RET      ;ELSE RETURN TO CALLER
151F                             ; 
151F   CD 22 10     ENDCHK:   CALL   IGNBLK   ;*** ENDCHK ***
1522   FE 0D                  CPI   CR   ;END WITH CR?
1524   C8                     RZ      ;OK, ELSE SAY: "WHAT?"
1525                             ; 
1525   D5           QWHAT:    PUSH   D   ;*** QWHAT ***
1526   11 B3 10     AWHAT:    LXI   D,WHAT   ;*** AWHAT ***
1529   97           ERROR:    SUB   A   ;*** ERROR ***
152A   CD C9 15               CALL   PRTSTG   ;PRINT "WHAT?", "HOW?"
152D   D1                     POP   D   ;OR "SORRY"
152E   1A                     LDAX   D   ;SAVE THE CHARACTER
152F   F5                     PUSH   PSW   ;AT WHERE OLD DE ->
1530   97                     SUB   A   ;AND PUT A 0 THERE
1531   12                     STAX   D   
1532   2A 01 80               LHLD   CURRNT   ;GET CURRENT LINE #
1535   E5                     PUSH   H   
1536   7E                     MOV   A,M   ;CHECK THE VALUE
1537   23                     INX   H   
1538   B6                     ORA   M   
1539   D1                     POP   D   
153A   CA BF 10               JZ   RSTART   ;IF ZERO, JUST RESTART
153D   7E                     MOV   A,M   ;IF NEGATIVE,
153E   B7                     ORA   A   
153F   FA F0 12               JM   INPERR   ;REDO INPUT
1542   CD 4B 16               CALL   PRTLN   ;ELSE PRINT THE LINE
1545   1B                     DCX   D   ;UPTO WHERE THE 0 IS
1546   F1                     POP   PSW   ;RESTORE THE CHARACTER
1547   12                     STAX   D   
1548   3E 3F                  MVI   A,3FH   ;PRINT A "?"
154A   CD 0A 10               CALL   OUTC   
154D   97                     SUB   A   ;AND THE REST OF THE
154E   CD C9 15               CALL   PRTSTG   ;LINE
1551   C3 BF 10               JMP   RSTART   ;THEN RESTART
1554                             ; 
1554   D5           QSORRY:   PUSH   D   ;*** QSORRY ***
1555   11 B9 10     ASORRY:   LXI   D,SORRY   ;*** ASORRY ***
1558   C3 29 15               JMP   ERROR   
155B                             ; 
155B                             ;*************************************************************
155B                             ; 
155B                             ; *** GETLN *** FNDLN (& FRIENDS) ***
155B                             ; 
155B                             ; "GETLN" READS A INPUT LINE INTO "BUFFER".  IT FIRST PROMPT
155B                             ; THE CHARACTER IN A (GIVEN BY THE CALLER), THEN IT FILLS
155B                             ; THE BUFFER AND ECHOS.  IT IGNORES LF'S AND NULLS, BUT STILL
155B                             ; ECHOS THEM BACK.  RUB-OUT IS USED TO CAUSE IT TO DELETE
155B                             ; THE LAST CHARACTER (IF THERE IS ONE), AND ALT-MOD IS USED TO
155B                             ; CAUSE IT TO DELETE THE WHOLE LINE AND START IT ALL OVER.
155B                             ; CR SIGNALS THE END OF A LINE, AND CAUSE "GETLN" TO RETURN.
155B                             ; 
155B                             ; "FNDLN" FINDS A LINE WITH A GIVEN LINE # (IN HL) IN THE
155B                             ; TEXT SAVE AREA.  DE IS USED AS THE TEXT POINTER.  IF THE
155B                             ; LINE IS FOUND, DE WILL POINT TO THE BEGINNING OF THAT LINE
155B                             ; (I.E., THE LOW BYTE OF THE LINE #), AND FLAGS ARE NC & Z.
155B                             ; IF THAT LINE IS NOT THERE AND A LINE WITH A HIGHER LINE #
155B                             ; IS FOUND, DE POINTS TO THERE AND FLAGS ARE NC & NZ.  IF
155B                             ; WE REACHED THE END OF TEXT SAVE AREA AND CANNOT FIND THE
155B                             ; LINE, FLAGS ARE C & NZ.
155B                             ; "FNDLN" WILL INITIALIZE DE TO THE BEGINNING OF THE TEXT SAVE
155B                             ; AREA TO START THE SEARCH.  SOME OTHER ENTRIES OF THIS
155B                             ; ROUTINE WILL NOT INITIALIZE DE AND DO THE SEARCH.
155B                             ; "FNDLNP" WILL START WITH DE AND SEARCH FOR THE LINE #.
155B                             ; "FNDNXT" WILL BUMP DE BY 2, FIND A CR AND THEN START SEARCH.
155B                             ; "FNDSKP" USE DE TO FIND A CR, AND THEN START SEARCH.
155B                             ; 
155B   CD 0A 10     GETLN:    CALL   OUTC   ;*** GETLN ***
155E   11 37 FC               LXI   D,BUFFER   ;PROMPT AND INIT.
1561   CD 03 17     GL1:      CALL   CHKIO   ;CHECK KEYBOARD
1564   CA 61 15               JZ   GL1   ;NO INPUT, WAIT
1567   FE 7F                  CPI   7FH   ;DELETE LAST CHARACTER?
1569   CA 88 15               JZ   GL3   ;YES
156C   CD 0A 10               CALL   OUTC   ;INPUT, ECHO BACK
156F   FE 0A                  CPI   0AH   ;IGNORE LF
1571   CA 61 15               JZ   GL1   
1574   B7                     ORA   A   ;IGNORE NULL
1575   CA 61 15               JZ   GL1   
1578   FE 7D                  CPI   7DH   ;DELETE THE WHOLE LINE?
157A   CA 97 15               JZ   GL4   ;YES
157D   12                     STAX   D   ;ELSE SAVE INPUT
157E   13                     INX   D   ;AND BUMP POINTER
157F   FE 0D                  CPI   0DH   ;WAS IT CR?
1581   C8                     RZ      ;YES, END OF LINE
1582   7B                     MOV   A,E   ;ELSE MORE FREE ROOM?
1583   FE 77                  CPI   <BUFEND   
1585   C2 61 15               JNZ   GL1   ;YES, GET NEXT INPUT
1588   7B           GL3:      MOV   A,E   ;DELETE LAST CHARACTER
1589   FE 37                  CPI   <BUFFER   ;BUT DO WE HAVE ANY?
158B   CA 97 15               JZ   GL4   ;NO, REDO WHOLE LINE
158E   1B                     DCX   D   ;YES, BACKUP POINTER
158F   3E 5C                  MVI   A,5CH   ;AND ECHO A BACK-SLASH
1591   CD 0A 10               CALL   OUTC   
1594   C3 61 15               JMP   GL1   ;GO GET NEXT INPUT
1597   CD 08 10     GL4:      CALL   CRLF   ;REDO ENTIRE LINE
159A   3E 5E                  MVI   A,05EH   ;CR, LF AND UP-ARROW
159C   C3 5B 15               JMP   GETLN   
159F                             ; 
159F   7C           FNDLN:    MOV   A,H   ;*** FNDLN ***
15A0   B7                     ORA   A   ;CHECK SIGN OF HL
15A1   FA A4 10               JM   QHOW   ;IT CANNOT BE -
15A4   11 17 80               LXI   D,TXTBGN   ;INIT TEXT POINTER
15A7                             ; 
15A7                FNDLP:       ;*** FDLNP ***
15A7   E5           FL1:      PUSH   H   ;SAVE LINE #
15A8   2A 15 80               LHLD   TXTUNF   ;CHECK IF WE PASSED END
15AB   2B                     DCX   H   
15AC   CD 1A 10               CALL   COMP   
15AF   E1                     POP   H   ;GET LINE # BACK
15B0   D8                     RC      ;C,NZ PASSED END
15B1   1A                     LDAX   D   ;WE DID NOT, GET BYTE 1
15B2   95                     SUB   L   ;IS THIS THE LINE?
15B3   47                     MOV   B,A   ;COMPARE LOW ORDER
15B4   13                     INX   D   
15B5   1A                     LDAX   D   ;GET BYTE 2
15B6   9C                     SBB   H   ;COMPARE HIGH ORDER
15B7   DA BE 15               JC   FL2   ;NO, NOT THERE YET
15BA   1B                     DCX   D   ;ELSE WE EITHER FOUND
15BB   B0                     ORA   B   ;IT, OR IT IS NOT THERE
15BC   C9                     RET      ;NC,Z:FOUND, NC,NZ:NO
15BD                             ; 
15BD                FNDNXT:      ;*** FNDNXT ***
15BD   13                     INX   D   ;FIND NEXT LINE
15BE   13           FL2:      INX   D   ;JUST PASSED BYTE 1 & 2
15BF                             ; 
15BF   1A           FNDSKP:   LDAX   D   ;*** FNDSKP ***
15C0   FE 0D                  CPI   CR   ;TRY TO FIND CR
15C2   C2 BE 15               JNZ   FL2   ;KEEP LOOKING
15C5   13                     INX   D   ;FOUND CR, SKIP OVER
15C6   C3 A7 15               JMP   FL1   ;CHECK IF END OF TEXT
15C9                             ; 
15C9                             ;*************************************************************
15C9                             ; 
15C9                             ; *** PRTSTG *** QTSTG *** PRTNUM *** & PRTLN ***
15C9                             ; 
15C9                             ; "PRTSTG" PRINTS A STRING POINTED BY DE.  IT STOPS PRINTING
15C9                             ; AND RETURNS TO CALLER WHEN EITHER A CR IS PRINTED OR WHEN
15C9                             ; THE NEXT BYTE IS THE SAME AS WHAT WAS IN A (GIVEN BY THE
15C9                             ; CALLER).  OLD A IS STORED IN B, OLD B IS LOST.
15C9                             ; 
15C9                             ; "QTSTG" LOOKS FOR A BACK-ARROW, SINGLE QUOTE, OR DOUBLE
15C9                             ; QUOTE.  IF NONE OF THESE, RETURN TO CALLER.  IF BACK-ARROW,
15C9                             ; OUTPUT A CR WITHOUT A LF.  IF SINGLE OR DOUBLE QUOTE, PRINT
15C9                             ; THE STRING IN THE QUOTE AND DEMANDS A MATCHING UNQUOTE.
15C9                             ; AFTER THE PRINTING THE NEXT 3 BYTES OF THE CALLER IS SKIPPED
15C9                             ; OVER (USUALLY A JUMP INSTRUCTION.
15C9                             ; 
15C9                             ; "PRTNUM" PRINTS THE NUMBER IN HL.  LEADING BLANKS ARE ADDED
15C9                             ; IF NEEDED TO PAD THE NUMBER OF SPACES TO THE NUMBER IN C.
15C9                             ; HOWEVER, IF THE NUMBER OF DIGITS IS LARGER THAN THE # IN
15C9                             ; C, ALL DIGITS ARE PRINTED ANYWAY.  NEGATIVE SIGN IS ALSO
15C9                             ; PRINTED AND COUNTED IN, POSITIVE SIGN IS NOT.
15C9                             ; 
15C9                             ; "PRTLN" PRINTS A SAVED TEXT LINE WITH LINE # AND ALL.
15C9                             ; 
15C9   47           PRTSTG:   MOV   B,A   ;*** PRTSTG ***
15CA   1A           PS1:      LDAX   D   ;GET A CHARACTER
15CB   13                     INX   D   ;BUMP POINTER
15CC   B8                     CMP   B   ;SAME AS OLD A?
15CD   C8                     RZ      ;YES, RETURN
15CE   CD 0A 10               CALL   OUTC   ;ELSE PRINT IT
15D1   FE 0D                  CPI   CR   ;WAS IT A CR?
15D3   C2 CA 15               JNZ   PS1   ;NO, NEXT
15D6   C9                     RET      ;YES, RETURN
15D7                             ; 
15D7   CD 66 10     QTSTG:    CALL   TSTC   ;*** QTSTG ***
15DA   22                     DB   22h   
15DB   0F                     DB   QT3-$-1   
15DC   3E 22                  MVI   A,22H   ;IT IS A "
15DE   CD C9 15     QT1:      CALL   PRTSTG   ;PRINT UNTIL ANOTHER
15E1   FE 0D                  CPI   CR   ;WAS LAST ONE A CR?
15E3   E1                     POP   H   ;RETURN ADDRESS
15E4   CA 50 11               JZ   RUNNXL   ;WAS CR, RUN NEXT LINE
15E7   23           QT2:      INX   H   ;SKIP 3 BYTES ON RETURN
15E8   23                     INX   H   
15E9   23                     INX   H   
15EA   E9                     PCHL      ;RETURN
15EB   CD 66 10     QT3:      CALL   TSTC   ;IS IT A '?
15EE   27                     DB   27H   
15EF   05                     DB   QT4-$-1   
15F0   3E 27                  MVI   A,27H   ;YES, DO THE SAME
15F2   C3 DE 15               JMP   QT1   ;AS IN "
15F5   CD 66 10     QT4:      CALL   TSTC   ;IS IT BACK-ARROW?
15F8   5F                     DB   5FH   
15F9   0C                     DB   QT5-$-1   
15FA   3E 8D                  MVI   A,08DH   ;YES, CR WITHOUT LF
15FC   CD 0A 10               CALL   OUTC   ;DO IT TWICE TO GIVE
15FF   CD 0A 10               CALL   OUTC   ;TTY ENOUGH TIME
1602   E1                     POP   H   ;RETURN ADDRESS
1603   C3 E7 15               JMP   QT2   
1606   C9           QT5:      RET      ;NONE OF ABOVE
1607                             ; 
1607   06 00        PRTNUM:   MVI   B,0   ;*** PRTNUM ***
1609   CD D4 14               CALL   CHKSGN   ;CHECK SIGN
160C   F2 12 16               JP   PN1   ;NO SIGN
160F   06 2D                  MVI   B,"-"   ;B=SIGN
1611   0D                     DCR   C   ;"-" TAKES SPACE
1612   D5           PN1:      PUSH   D   ;SAVE
1613   11 0A 00               LXI   D,0AH   ;DECIMAL
1616   D5                     PUSH   D   ;SAVE AS A FLAG
1617   0D                     DCR   C   ;C=SPACES
1618   C5                     PUSH   B   ;SAVE SIGN & SPACE
1619   CD B7 14     PN2:      CALL   DIVIDE   ;DIVIDE HL BY 10
161C   78                     MOV   A,B   ;RESULT 0?
161D   B1                     ORA   C   
161E   CA 29 16               JZ   PN3   ;YES, WE GOT ALL
1621   E3                     XTHL      ;NO, SAVE REMAINDER
1622   2D                     DCR   L   ;AND COUNT SPACE
1623   E5                     PUSH   H   ;HL IS OLD BC
1624   60                     MOV   H,B   ;MOVE RESULT TO BC
1625   69                     MOV   L,C   
1626   C3 19 16               JMP   PN2   ;AND DIVIDE BY 10
1629   C1           PN3:      POP   B   ;WE GOT ALL DIGITS IN
162A   0D           PN4:      DCR   C   ;THE STACK
162B   79                     MOV   A,C   ;LOOK AT SPACE COUNT
162C   B7                     ORA   A   
162D   FA 38 16               JM   PN5   ;NO LEADING BLANKS
1630   3E 20                  MVI   A,20H   ;LEADING BLANKS
1632   CD 0A 10               CALL   OUTC   
1635   C3 2A 16               JMP   PN4   ;MORE?
1638   78           PN5:      MOV   A,B   ;PRINT SIGN
1639   B7                     ORA   A   
163A   C4 10 00               CNZ   10H   
163D   5D                     MOV   E,L   ;LAST REMAINDER IN E
163E   7B           PN6:      MOV   A,E   ;CHECK DIGIT IN E
163F   FE 0A                  CPI   0AH   ;10 IS FLAG FOR NO MORE
1641   D1                     POP   D   
1642   C8                     RZ      ;IF SO, RETURN
1643   C6 30                  ADI   30H   ;ELSE CONVERT TO ASCII
1645   CD 0A 10               CALL   OUTC   ;AND PRINT THE DIGIT
1648   C3 3E 16               JMP   PN6   ;GO BACK FOR MORE
164B                             ; 
164B   1A           PRTLN:    LDAX   D   ;*** PRTLN ***
164C   6F                     MOV   L,A   ;LOW ORDER LINE #
164D   13                     INX   D   
164E   1A                     LDAX   D   ;HIGH ORDER
164F   67                     MOV   H,A   
1650   13                     INX   D   
1651   0E 04                  MVI   C,4H   ;PRINT 4 DIGIT LINE #
1653   CD 07 16               CALL   PRTNUM   
1656   3E 20                  MVI   A,20H   ;FOLLOWED BY A BLANK
1658   CD 0A 10               CALL   OUTC   
165B   97                     SUB   A   ;AND THEN THE NEXT
165C   CD C9 15               CALL   PRTSTG   
165F   C9                     RET      
1660                             ; 
1660                             ;*************************************************************
1660                             ; 
1660                             ; *** MVUP *** MVDOWN *** POPA *** & PUSHA ***
1660                             ; 
1660                             ; "MVUP" MOVES A BLOCK UP FROM WHERE DE-> TO WHERE BC-> UNTIL
1660                             ; DE = HL
1660                             ; 
1660                             ; "MVDOWN" MOVES A BLOCK DOWN FROM WHERE DE-> TO WHERE HL->
1660                             ; UNTIL DE = BC
1660                             ; 
1660                             ; "POPA" RESTORES THE "FOR" LOOP VARIABLE SAVE AREA FROM THE
1660                             ; STACK
1660                             ; 
1660                             ; "PUSHA" STACKS THE "FOR" LOOP VARIABLE SAVE AREA INTO THE
1660                             ; STACK
1660                             ; 
1660   CD 1A 10     MVUP:     CALL   COMP   ;*** MVUP ***
1663   C8                     RZ      ;DE = HL, RETURN
1664   1A                     LDAX   D   ;GET ONE BYTE
1665   02                     STAX   B   ;MOVE IT
1666   13                     INX   D   ;INCREASE BOTH POINTERS
1667   03                     INX   B   
1668   C3 60 16               JMP   MVUP   ;UNTIL DONE
166B                             ; 
166B   78           MVDOWN:   MOV   A,B   ;*** MVDOWN ***
166C   92                     SUB   D   ;TEST IF DE = BC
166D   C2 73 16               JNZ   MD1   ;NO, GO MOVE
1670   79                     MOV   A,C   ;MAYBE, OTHER BYTE?
1671   93                     SUB   E   
1672   C8                     RZ      ;YES, RETURN
1673   1B           MD1:      DCX   D   ;ELSE MOVE A BYTE
1674   2B                     DCX   H   ;BUT FIRST DECREASE
1675   1A                     LDAX   D   ;BOTH POINTERS AND
1676   77                     MOV   M,A   ;THEN DO IT
1677   C3 6B 16               JMP   MVDOWN   ;LOOP BACK
167A                             ; 
167A   C1           POPA:     POP   B   ;BC = RETURN ADDR.
167B   E1                     POP   H   ;RESTORE LOPVAR, BUT
167C   22 09 80               SHLD   LOPVAR   ;=0 MEANS NO MORE
167F   7C                     MOV   A,H   
1680   B5                     ORA   L   
1681   CA 94 16               JZ   PP1   ;YEP, GO RETURN
1684   E1                     POP   H   ;NOP, RESTORE OTHERS
1685   22 0B 80               SHLD   LOPINC   
1688   E1                     POP   H   
1689   22 0D 80               SHLD   LOPLMT   
168C   E1                     POP   H   
168D   22 0F 80               SHLD   LOPLN   
1690   E1                     POP   H   
1691   22 11 80               SHLD   LOPPT   
1694   C5           PP1:      PUSH   B   ;BC = RETURN ADDR.
1695   C9                     RET      
1696                             ; 
1696   21 78 FC     PUSHA:    LXI   H,STKLMT   ;*** PUSHA ***
1699   CD D7 14               CALL   CHGSGN   
169C   C1                     POP   B   ;BC=RETURN ADDRESS
169D   39                     DAD   SP   ;IS STACK NEAR THE TOP?
169E   D2 54 15               JNC   QSORRY   ;YES, SORRY FOR THAT
16A1   2A 09 80               LHLD   LOPVAR   ;ELSE SAVE LOOP VAR'S
16A4   7C                     MOV   A,H   ;BUT IF LOPVAR IS 0
16A5   B5                     ORA   L   ;THAT WILL BE ALL
16A6   CA BC 16               JZ   PU1   
16A9   2A 11 80               LHLD   LOPPT   ;ELSE, MORE TO SAVE
16AC   E5                     PUSH   H   
16AD   2A 0F 80               LHLD   LOPLN   
16B0   E5                     PUSH   H   
16B1   2A 0D 80               LHLD   LOPLMT   
16B4   E5                     PUSH   H   
16B5   2A 0B 80               LHLD   LOPINC   
16B8   E5                     PUSH   H   
16B9   2A 09 80               LHLD   LOPVAR   
16BC   E5           PU1:      PUSH   H   
16BD   C5                     PUSH   B   ;BC = RETURN ADDR.
16BE   C9                     RET      
16BF                             ; 
16BF                             ;*************************************************************
16BF                             ; 
16BF                             ; *** OUTC *** & CHKIO ***
16BF                             ; 
16BF                             ; THESE ARE THE ONLY I/O ROUTINES IN TBI.
16BF                             ; "OUTC" IS CONTROLLED BY A SOFTWARE SWITCH "OCSW".  IF OCSW=0
16BF                             ; "OUTC" WILL JUST RETURN TO THE CALLER.  IF OCSW IS NOT 0,
16BF                             ; IT WILL OUTPUT THE BYTE IN A.  IF THAT IS A CR, A LF IS ALSO
16BF                             ; SEND OUT.  ONLY THE FLAGS MAY BE CHANGED AT RETURN. ALL REG.
16BF                             ; ARE RESTORED.
16BF                             ; 
16BF                             ; "CHKIO" CHECKS THE INPUT.  IF NO INPUT, IT WILL RETURN TO
16BF                             ; THE CALLER WITH THE Z FLAG SET.  IF THERE IS INPUT, Z FLAG
16BF                             ; IS CLEARED AND THE INPUT BYTE IS IN A.  HOWEVER, IF THE
16BF                             ; INPUT IS A CONTROL-O, THE "OCSW" SWITCH IS COMPLIMENTED, AND
16BF                             ; Z FLAG IS RETURNED.  IF A CONTROL-C IS READ, "CHKIO" WILL
16BF                             ; RESTART TBI AND DO NOT RETURN TO THE CALLER.
16BF                             ; 
16BF                             ;OUTC:  PUSH PSW                        ;THIS IS AT LOC. 10
16BF                             ;       LDA  OCSW                       ;CHECK SOFTWARE SWITCH
16BF                             ;       ORA  A
16BF                             ; 
16BF                ACIA_C:   EQU   0DEh   
16BF                ACIA_D:   EQU   0DFh   
16BF                             ; 
16BF   32 00 80     INIT:     STA   OCSW   
16C2   3E 03                  MVI   A,3   ;RESET ACIA
16C4   D3 10                  OUT   16   
16C6   3E 15                  MVI   A,15H   ;15H FOR 8N1, 11H FOR 8N2
16C8   D3 10                  OUT   16   
16CA   16 19                  MVI   D,19H   
16CC                PATLOP:      
16CC   CD 08 10               CALL   CRLF   
16CF   15                     DCR   D   
16D0   C2 CC 16               JNZ   PATLOP   
16D3   97                     SUB   A   
16D4   11 22 17               LXI   D,MSG1   
16D7   CD C9 15               CALL   PRTSTG   
16DA   21 00 10               LXI   H,START   
16DD   22 13 80               SHLD   RANPNT   
16E0   21 17 80               LXI   H,TXTBGN   
16E3   22 15 80               SHLD   TXTUNF   
16E6   C3 BF 10               JMP   RSTART   
16E9   C2 EE 16     OC2:      JNZ   OC3   ;IT IS ON
16EC   F1                     POP   PSW   ;IT IS OFF
16ED   C9                     RET      ;RESTORE AF AND RETURN
16EE   DB DE        OC3:      IN   ACIA_C   ;COME HERE TO DO OUTPUT
16F0   E6 02                  ANI   2H   ;STATUS BIT
16F2   CA EE 16               JZ   OC3   ;NOT READY, WAIT
16F5   F1                     POP   PSW   ;READY, GET OLD A BACK
16F6   D3 DF                  OUT   ACIA_D   ;AND SEND IT OUT
16F8   FE 0D                  CPI   CR   ;WAS IT CR?
16FA   C0                     RNZ      ;NO, FINISHED
16FB   3E 0A                  MVI   A,LF   ;YES, WE SEND LF TOO
16FD   CD 0A 10               CALL   OUTC   ;THIS IS RECURSIVE
1700   3E 0D                  MVI   A,CR   ;GET CR BACK IN A
1702   C9                     RET      
1703                             ; 
1703   DB DE        CHKIO:    IN   ACIA_C   ;*** CHKIO ***
1705   00                     NOP      ;STATUS BIT FLIPPED?
1706   E6 01                  ANI   01H   ;MASK STATUS BIT
1708   C8                     RZ      ;NOT READY, RETURN "Z"
1709   DB DF                  IN   ACIA_D   ;READY, READ DATA
170B   E6 7F                  ANI   7FH   ;MASK BIT 7 OFF
170D   FE 0F                  CPI   0FH   ;IS IT CONTROL-O?
170F   C2 1C 17               JNZ   CI1   ;NO, MORE CHECKING
1712   3A 00 80               LDA   OCSW   ;CONTROL-O FLIPS OCSW
1715   2F                     CMA      ;ON TO OFF, OFF TO ON
1716   32 00 80               STA   OCSW   
1719   C3 03 17               JMP   CHKIO   ;GET ANOTHER INPUT
171C   FE 03        CI1:      CPI   3H   ;IS IT CONTROL-C?
171E   C0                     RNZ      ;NO, RETURN "NZ"
171F   C3 BF 10               JMP   RSTART   ;YES, RESTART TBI
1722                             ; 
1722   54 49 4E 59 20 MSG1:   DB   "TINY "   
1727   42 41 53 49 43         DB   "BASIC"   
172C   0D                     DB   CR   
172D                             ; 
172D                             ;*************************************************************
172D                             ; 
172D                             ; *** TABLES *** DIRECT *** & EXEC ***
172D                             ; 
172D                             ; THIS SECTION OF THE CODE TESTS A STRING AGAINST A TABLE.
172D                             ; WHEN A MATCH IS FOUND, CONTROL IS TRANSFERED TO THE SECTION
172D                             ; OF CODE ACCORDING TO THE TABLE.
172D                             ; 
172D                             ; AT "EXEC", DE SHOULD POINT TO THE STRING AND HL SHOULD POINT
172D                             ; TO THE TABLE-1.  AT "DIRECT", DE SHOULD POINT TO THE STRING.
172D                             ; HL WILL BE SET UP TO POINT TO TAB1-1, WHICH IS THE TABLE OF
172D                             ; ALL DIRECT AND STATEMENT COMMANDS.
172D                             ; 
172D                             ; A "." IN THE STRING WILL TERMINATE THE TEST AND THE PARTIAL
172D                             ; MATCH WILL BE CONSIDERED AS A MATCH.  E.G., "P.", "PR.",
172D                             ; "PRI.", "PRIN.", OR "PRINT" WILL ALL MATCH "PRINT".
172D                             ; 
172D                             ; THE TABLE CONSISTS OF ANY NUMBER OF ITEMS.  EACH ITEM
172D                             ; IS A STRING OF CHARACTERS WITH BIT 7 SET TO 0 AND
172D                             ; A JUMP ADDRESS STORED HI-LOW WITH BIT 7 OF THE HIGH
172D                             ; BYTE SET TO 1.
172D                             ; 
172D                             ; END OF TABLE IS AN ITEM WITH A JUMP ADDRESS ONLY.  IF THE
172D                             ; STRING DOES NOT MATCH ANY OF THE OTHER ITEMS, IT WILL
172D                             ; MATCH THIS NULL ITEM AS DEFAULT.
172D                             ; 
172D                TAB1:        ;DIRECT COMMANDS
172D   4C 49 53 54            DB   "LIST"   
1731                          ;*Macro unroll:  DWA     LIST 
1731   91                     DB   >LIST + 128   
1732   7A                     DB   <LIST   
1733   52 55 4E               DB   "RUN"   
1736                          ;*Macro unroll:  DWA     RUN 
1736   91                     DB   >RUN + 128   
1737   4A                     DB   <RUN   
1738   4E 45 57               DB   "NEW"   
173B                          ;*Macro unroll:  DWA     NEW 
173B   91                     DB   >NEW + 128   
173C   3B                     DB   <NEW   
173D                             ; 
173D                TAB2:        ;DIRECT/STATEMENT
173D   4E 45 58 54            DB   "NEXT"   
1741                          ;*Macro unroll:  DWA     NEXT 
1741   92                     DB   >NEXT + 128   
1742   7A                     DB   <NEXT   
1743   4C 45 54               DB   "LET"   
1746                          ;*Macro unroll:  DWA     LET 
1746   93                     DB   >LET + 128   
1747   5A                     DB   <LET   
1748   49 46                  DB   "IF"   
174A                          ;*Macro unroll:  DWA     IFF 
174A   92                     DB   >IFF + 128   
174B   DF                     DB   <IFF   
174C   47 4F 54 4F            DB   "GOTO"   
1750                          ;*Macro unroll:  DWA     GOTO 
1750   91                     DB   >GOTO + 128   
1751   69                     DB   <GOTO   
1752   47 4F 53 55 42         DB   "GOSUB"   
1757                          ;*Macro unroll:  DWA     GOSUB 
1757   91                     DB   >GOSUB + 128   
1758   D8                     DB   <GOSUB   
1759   52 45 54 55 52 4E      DB   "RETURN"   
175F                          ;*Macro unroll:  DWA     RETURN 
175F   91                     DB   >RETURN + 128   
1760   FA                     DB   <RETURN   
1761   52 45 4D               DB   "REM"   
1764                          ;*Macro unroll:  DWA     REM 
1764   92                     DB   >REM + 128   
1765   DB                     DB   <REM   
1766   46 4F 52               DB   "FOR"   
1769                          ;*Macro unroll:  DWA     FOR 
1769   92                     DB   >FOR + 128   
176A   15                     DB   <FOR   
176B   49 4E 50 55 54         DB   "INPUT"   
1770                          ;*Macro unroll:  DWA     INPUT 
1770   92                     DB   >INPUT + 128   
1771   FA                     DB   <INPUT   
1772   50 52 49 4E 54         DB   "PRINT"   
1777                          ;*Macro unroll:  DWA     PRINT 
1777   91                     DB   >PRINT + 128   
1778   92                     DB   <PRINT   
1779   53 54 4F 50            DB   "STOP"   
177D                          ;*Macro unroll:  DWA     STOP 
177D   91                     DB   >STOP + 128   
177E   44                     DB   <STOP   
177F                          ;*Macro unroll:  DWA     DEFLT 
177F   93                     DB   >DEFLT + 128   
1780   54                     DB   <DEFLT   
1781                             ; 
1781                TAB4:        ;FUNCTIONS
1781   52 4E 44               DB   "RND"   
1784                          ;*Macro unroll:  DWA     RND 
1784   94                     DB   >RND + 128   
1785   74                     DB   <RND   
1786   41 42 53               DB   "ABS"   
1789                          ;*Macro unroll:  DWA     ABS 
1789   94                     DB   >ABS + 128   
178A   A1                     DB   <ABS   
178B   53 49 5A 45            DB   "SIZE"   
178F                          ;*Macro unroll:  DWA     SIZE 
178F   94                     DB   >SIZE + 128   
1790   AA                     DB   <SIZE   
1791                          ;*Macro unroll:  DWA     XP40 
1791   94                     DB   >XP40 + 128   
1792   52                     DB   <XP40   
1793                             ; 
1793                TAB5:        ;"TO" IN "FOR"
1793   54 4F                  DB   "TO"   
1795                          ;*Macro unroll:  DWA     FR1 
1795   92                     DB   >FR1 + 128   
1796   25                     DB   <FR1   
1797                          ;*Macro unroll:  DWA     QWHAT 
1797   95                     DB   >QWHAT + 128   
1798   25                     DB   <QWHAT   
1799                             ; 
1799                TAB6:        ;"STEP" IN "FOR"
1799   53 54 45 50            DB   "STEP"   
179D                          ;*Macro unroll:  DWA     FR2 
179D   92                     DB   >FR2 + 128   
179E   31                     DB   <FR2   
179F                          ;*Macro unroll:  DWA     FR3 
179F   92                     DB   >FR3 + 128   
17A0   37                     DB   <FR3   
17A1                             ; 
17A1                TAB8:        ;RELATION OPERATORS
17A1   3E 3D                  DB   ">="   
17A3                          ;*Macro unroll:  DWA     XP11 
17A3   93                     DB   >XP11 + 128   
17A4   6E                     DB   <XP11   
17A5   23                     DB   "#"   
17A6                          ;*Macro unroll:  DWA     XP12 
17A6   93                     DB   >XP12 + 128   
17A7   74                     DB   <XP12   
17A8   3E                     DB   ">"   
17A9                          ;*Macro unroll:  DWA     XP13 
17A9   93                     DB   >XP13 + 128   
17AA   7A                     DB   <XP13   
17AB   3D                     DB   "="   
17AC                          ;*Macro unroll:  DWA     XP15 
17AC   93                     DB   >XP15 + 128   
17AD   89                     DB   <XP15   
17AE   3C 3D                  DB   "<="   
17B0                          ;*Macro unroll:  DWA     XP14 
17B0   93                     DB   >XP14 + 128   
17B1   81                     DB   <XP14   
17B2   3C                     DB   "<"   
17B3                          ;*Macro unroll:  DWA     XP16 
17B3   93                     DB   >XP16 + 128   
17B4   8F                     DB   <XP16   
17B5                          ;*Macro unroll:  DWA     XP17 
17B5   93                     DB   >XP17 + 128   
17B6   95                     DB   <XP17   
17B7                             ; 
17B7   21 2C 17     DIRECT:   LXI   H,TAB1-1   ;*** DIRECT ***
17BA                             ; 
17BA                EXEC:        ;*** EXEC ***
17BA   CD 22 10     EX0:      CALL   IGNBLK   ;IGNORE LEADING BLANKS
17BD   D5                     PUSH   D   ;SAVE POINTER
17BE   1A           EX1:      LDAX   D   ;IF FOUND "." IN STRING
17BF   13                     INX   D   ;BEFORE ANY MISMATCH
17C0   FE 2E                  CPI   2EH   ;WE DECLARE A MATCH
17C2   CA DB 17               JZ   EX3   
17C5   23                     INX   H   ;HL->TABLE
17C6   BE                     CMP   M   ;IF MATCH, TEST NEXT
17C7   CA BE 17               JZ   EX1   
17CA   3E 7F                  MVI   A,07FH   ;ELSE SEE IF BIT 7
17CC   1B                     DCX   D   ;OF TABLE IS SET, WHICH
17CD   BE                     CMP   M   ;IS THE JUMP ADDR. (HI)
17CE   DA E2 17               JC   EX5   ;C:YES, MATCHED
17D1   23           EX2:      INX   H   ;NC:NO, FIND JUMP ADDR.
17D2   BE                     CMP   M   
17D3   D2 D1 17               JNC   EX2   
17D6   23                     INX   H   ;BUMP TO NEXT TAB. ITEM
17D7   D1                     POP   D   ;RESTORE STRING POINTER
17D8   C3 BA 17               JMP   EX0   ;TEST AGAINST NEXT ITEM
17DB   3E 7F        EX3:      MVI   A,07FH   ;PARTIAL MATCH, FIND
17DD   23           EX4:      INX   H   ;JUMP ADDR., WHICH IS
17DE   BE                     CMP   M   ;FLAGGED BY BIT 7
17DF   D2 DD 17               JNC   EX4   
17E2   7E           EX5:      MOV   A,M   ;LOAD HL WITH THE JUMP
17E3   23                     INX   H   ;ADDRESS FROM THE TABLE
17E4   6E                     MOV   L,M   
17E5   E6 7F                  ANI   7FH   ;MASK OFF BIT 7
17E7   67                     MOV   H,A   
17E8   F1                     POP   PSW   ;CLEAN UP THE GABAGE
17E9   E9                     PCHL      ;AND WE GO DO IT
17EA                             ; 
17EA                LSTROM:      ;ALL ABOVE CAN BE ROM
8000                          .ORG   8000H   ;HERE DOWN MUST BE RAM
8000                             ;       ORG  0800H
8000                OCSW:     DS   1   ;SWITCH FOR OUTPUT
8001                CURRNT:   DS   2   ;POINTS TO CURRENT LINE
8003                STKGOS:   DS   2   ;SAVES SP IN "GOSUB"
8005                VARNXT:   DS   2   ;TEMP STORAGE
8007                STKINP:   DS   2   ;SAVES SP IN "INPUT"
8009                LOPVAR:   DS   2   ;"FOR" LOOP SAVE AREA
800B                LOPINC:   DS   2   ;INCREMENT
800D                LOPLMT:   DS   2   ;LIMIT
800F                LOPLN:    DS   2   ;LINE NUMBER
8011                LOPPT:    DS   2   ;TEXT POINTER
8013                RANPNT:   DS   2   ;RANDOM NUMBER POINTER
8015                TXTUNF:   DS   2   ;->UNFILLED TEXT AREA
8017                TXTBGN:   DS   2   ;TEXT SAVE AREA BEGINS
FC00                          .ORG   0fc00H   
FC00                             ;       ORG  1F00H
FC00                TXTEND:   DS   0   ;TEXT SAVE AREA ENDS
FC00                VARBGN:   DS   55   ;VARIABLE @(0)
FC37                BUFFER:   DS   64   ;INPUT BUFFER
FC77                BUFEND:   DS   1   ;BUFFER ENDS
FC78                STKLMT:   DS   1   ;TOP LIMIT FOR STACK
FFFF                          .ORG   0ffffH   
FFFF                             ;       ORG  2000H
FFFF                STACK:    DS   0   ;STACK STARTS HERE
FFFF                             ; 
FFFF                CR:       EQU   0DH   
FFFF                LF:       EQU   0AH   
FFFF                             ; 
FFFF                          END      


